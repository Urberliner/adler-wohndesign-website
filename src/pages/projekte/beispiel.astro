---
// /projekte/beispiel — Projekt-Artikel-DETAILSEITE (Platzhalter/Template).
// VORLAGE für die spätere dynamische Route src/pages/projekte/[slug].astro mit CMS (Sanity).
//   → FLAG: Inhalte (Texte/Bilder/Specs/Related) hier als Platzhalter fest verdrahtet; beim
//     CMS-Schritt aus dem Datensatz speisen (Astro.params.slug → getStaticPaths).
//
// 1:1 aus Figma V4 (fileKey AryB7Db9AeJFgXmfBEsvpn), Section 5660:17423 „003-Projekte/001-Artikel".
// Drei Breakpoint-Frames (Inhalt):
//   L 6410:37056 (≥992) · M 6319:53879 (701–991) · S 5660:19671 (≤700)
// Werte/Texte/Tokens AUSSCHLIESSLICH aus get_design_context + get_variable_defs der drei Frames.
//
// Annotation (erstes „Text Container", alle 3 BP, Node 6410:37063 / 6319:53886 / 6029:34090):
//   „Desktop: vertikale Anordnung · spacing Gutter · Fill container /
//    mobil + tablet: horizontal Anordnung · spacing ML · Fill container"
//   Umsetzung nach den ECHTEN Frames (Regel „Frame gewinnt"): Information Overview + Intro-Text
//   bilden auf Desktop ZWEI fillende Spalten (gap ML), auf Tablet/Mobil gestapelt (gap ML).
//
// Layout-Aufbau (alle BP):
//   Hero (Breadcrumb + H1, dann full-bleed Bild) → Artikel (Info-Overview + Intro · Bild-Strip ·
//   alternierende H4-Textblöcke · full-bleed Bild · Bild-Collage · Bild-Platzhalter) →
//   Related Articles (nature) → Kontakt (Cta).
//
// Auf Desktop haben die H4-Textblöcke je eine zweite, im Figma LEERE Bild-Platzhalterspalte
// (alternierend links/rechts). Auf Tablet/Mobil entfällt diese Spalte (nur Text). 1:1 wie Frames.
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Carousel from "../../components/Carousel.astro";
import Card from "../../components/Card.astro";
import Cta from "../../components/Cta.astro";

// PLATZHALTER-Bilder = benannte Assets (echte Projektbilder folgen mit dem CMS).
// Dateinamen entsprechen den Figma-Layer-Namen, damit die Zuordnung später eindeutig bleibt.
const heroImage = {
  src: "/images/projekte/dachgeschoss-fenster-rollo-backstein.jpg",
  alt: "Dachgeschosswohnung mit großen Dachfenstern, Rollos und Backsteinwand",
};

// Information Overview — Spec-Liste (später CMS-Felder).
const specs = [
  { label: "Kategorie", value: ["Dachgeschosswohnung", "Altbau"], tone: "moos" },
  { label: "Jahr", value: ["2020"] },
  { label: "Ort", value: ["Westberlin"] },
  { label: "Leistungen", value: ["Gardinen", "Farbgebung", "Lichtkonzept"] },
];

const introParas = [
  "Ein Zuhause, in dem Licht, Raum und Atmosphäre im perfekten Gleichgewicht stehen: Diese Dachgeschosswohnung in Berlin-Friedrichshain vereint urbanen Charme mit durchdachter Gestaltung und meisterhaftem Handwerk. Großzügige Fensterfronten lassen den Himmel über Berlin herein – und stellen zugleich höchste Ansprüche an Sicht- und Sonnenschutz. Unsere Aufgabe: eine Lösung entwickeln, die Funktionalität, Ästhetik und Wohnkomfort in Einklang bringt.",
  "Mit maßgeschneiderten Gardinen, einem stimmigen Farbkonzept und clever integrierter Technik haben wir ein Raumgefühl geschaffen, das den Charakter der Wohnung unterstreicht und ihre Großzügigkeit betont. Jedes Detail, vom Stoff bis zur Schienentechnik, wurde präzise geplant und perfekt umgesetzt – für ein Ergebnis, das nicht nur schön aussieht, sondern jeden Tag erlebbar wird.",
];

// Bild-Strip („Image Carousel" 6467:72063) — 4 Kacheln, Seitenverhältnisse 160/360/360/160 : 240.
const strip = [
  { src: "/images/projekte/strip-1.jpg", alt: "Detailaufnahme der maßgefertigten Dachfenster-Gardine", ratio: "160 / 240" },
  { src: "/images/projekte/strip-2.jpg", alt: "Wohnraum mit bodentiefen Vorhängen am Tag", ratio: "360 / 240" },
  { src: "/images/projekte/strip-3.jpg", alt: "Lichtstimmung im Dachgeschoss am Abend", ratio: "360 / 240" },
  { src: "/images/projekte/strip-4.jpg", alt: "Nahaufnahme der eingelassenen Schienentechnik", ratio: "160 / 240" },
];

// Alternierende H4-Textblöcke (Reihenfolge wie Frames). placeholder = Seite der leeren
// Desktop-Bildspalte (links/rechts), ab Tablet entfällt sie.
const textBlocks1 = [
  {
    heading: "Perfektes Zusammenspiel von Funktion und Ästhetik",
    body: "Die großflächigen Fenster dieser Wohnung ließen viel natürliches Licht herein, machten jedoch den Einsatz eines effektiven Sicht- und Sonnenschutzes unerlässlich. Die Vorgabe: Funktionale Lösungen, die technisch ausgereift sind, sich aber optisch nahtlos ins Design einfügen. Unsere Lösung: Maßgeschneiderte Gardinen für die Dachfenster, kombiniert mit perfekt abgestimmten Vorhängen für eine angenehme Raumakustik und eine behagliche Wohnatmosphäre.",
    placeholder: "right",
  },
  {
    heading: "Stilvolle Wohnlichkeit mit maßgeschneiderten Gardinen",
    body: "Dachgeschosswohnungen sind einzigartig – sie bieten beeindruckende Raumhöhen, außergewöhnliche Lichteinfälle und eine ganz besondere Atmosphäre. Doch gerade bei großen Fensterfronten kann es eine Herausforderung sein, Sicht- und Sonnenschutz harmonisch in das Wohnkonzept zu integrieren. Bei diesem Projekt in einer großzügigen 5-Zimmer-Dachgeschosswohnung in Berlin-Friedrichshain haben wir genau diese Herausforderung gemeistert – mit maßgeschneiderten Gardinenlösungen und einer intelligenten Farbgestaltung, die den Raum in seiner ganzen Schönheit unterstreicht.",
    placeholder: "left",
  },
];

const fullImage = {
  src: "/images/projekte/dachgeschoss-wohnraum-vorhaenge.jpg",
  alt: "Wohnraum der Dachgeschosswohnung mit bodentiefen Vorhängen und abgestimmtem Farbkonzept",
};

const textBlocks2 = [
  {
    heading: "Intelligente Farbwahl für ein harmonisches Wohngefühl",
    body: "Farben beeinflussen die Wahrnehmung eines Raumes erheblich – und bei diesem Projekt haben wir gezielt mit ihnen gearbeitet. Um die großzügige Raumwirkung zu unterstreichen, haben wir die Wandfarbe auch an den Decken eingesetzt. Die geradlinigen, bodentiefen Vorhänge in zwei fein abgestimmten Farbtönen setzen klare Akzente, ohne den Raum zu überladen. Transparente, dunkle Stores sorgen für eine angenehme Lichtstimmung am Tag, während helle, gefütterte Vorhänge in den Abendstunden eine sanfte, wohnliche Wirkung entfalten.",
    placeholder: "right",
  },
  {
    heading: "Präzise Planung für ein makelloses Ergebnis",
    body: "Ein durchdachtes Raumkonzept braucht sorgfältige Planung – das gilt besonders für unsichtbare Schienensysteme, die für eine nahtlose Integration der Gardinen sorgen. Bei diesem Projekt haben wir die Platzverhältnisse exakt berechnet und zwei Schienensysteme elegant in die Deckenverkofferung integriert. Wo dies nicht möglich war, wurden die Schienen in der Deckenfarbe pulverbeschichtet – für eine dezente, stilvolle Lösung.",
    placeholder: "left",
  },
];

// Bild-Collage („Collage S 1" 6410:37088): hohe Spalte links + zwei gestapelte Bilder rechts.
const collage = {
  main: { src: "/images/projekte/dachgeschoss-fenster-rollo-backstein.jpg", alt: "Dachfenster mit Rollo vor Backsteinwand" },
  topRight: { src: "/images/projekte/dachgeschoss-sichtschutz-sonnenschutz-rollos-designerteppich.jpg", alt: "Sicht- und Sonnenschutz-Rollos mit Designerteppich im Dachgeschoss" },
  bottomRight: { src: "/images/projekte/dachfenster-rollos-sichtschutz-dachgeschoss-grosse-fenster.jpg", alt: "Dachfenster-Rollos als Sichtschutz an großen Fenstern" },
};

// Einzelner Bild-Platzhalter (horizontal-spacing-fill, h 240).
const wideImage = {
  src: "/images/projekte/dachgeschoss-gesamtansicht.jpg",
  alt: "Gesamtansicht des fertig gestalteten Dachgeschoss-Wohnraums",
};

const resultBlock = {
  heading: "Ein Ergebnis, das begeistert",
  body: "Innerhalb von nur acht Wochen haben wir das gesamte Projekt von der ersten Beratung bis zur finalen Umsetzung realisiert. Die Abstimmung erfolgte flexibel per Telefon und E-Mail, sodass sich der Auftraggeber voll und ganz auf seinen Alltag konzentrieren konnte. Das Ergebnis: Ein perfekt harmonisiertes Wohnkonzept, das durch durchdachten Sicht- und Sonnenschutz sowie eine stilvolle Farbgestaltung überzeugt. Die Empfehlung unseres zufriedenen Kunden ist für uns das größte Kompliment – herzlichen Dank dafür!",
  placeholder: "right",
};

// Related Articles („Das könnte Ihnen auch gefallen") — Platzhalter, später CMS-Verlinkung.
const related = [
  { eyebrow: "Wohnträume", title: "Sie haben einen Wunschtraum?", img: "/images/projekte/related-1.jpg", href: "/projekte/beispiel" },
  { eyebrow: "Wohnträume", title: "Sie haben einen Wunschtraum?", img: "/images/projekte/related-2.jpg", href: "/projekte/beispiel" },
  { eyebrow: "Wohnträume", title: "Sie haben einen Wunschtraum?", img: "/images/projekte/related-3.jpg", href: "/projekte/beispiel" },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Licht, Raum, Atmosphäre – Perfekte Lösungen für Dachfenster | ADLER Wohndesign</title>
    <meta
      name="description"
      content="Projektbeispiel von ADLER Wohndesign: maßgeschneiderte Gardinen, ein stimmiges Farbkonzept und clever integrierte Technik für eine Dachgeschosswohnung in Berlin-Friedrichshain."
    />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <Header />

    <main>
      <!-- HERO — Frame „Hero" 6423:41672 / 6423:41659 / 5660:19673 -->
      <section class="hero">
        <div class="container hero__intro">
          <div class="hero__text">
            <p class="t-titel breadcrumb">
              <a href="/projekte" class="bc-link">Projekte</a><span class="bc-sep">&nbsp;&gt;&nbsp;</span><span class="bc-current">Ein Berliner Klassiker</span>
            </p>
            <h1 class="t-h1">Licht, Raum, Atmosphäre – Perfekte Lösungen für Dachfenster</h1>
          </div>
        </div>
        <div class="hero__image">
          <img src={heroImage.src} alt={heroImage.alt} fetchpriority="high" />
        </div>
      </section>

      <!-- ARTIKEL — Frame „Artikel" 6410:37062 / 6319:53885 / 5660:19672 -->
      <article class="artikel">
        <!-- 1. Info Overview + Intro (Desktop 2-spaltig, sonst gestapelt — Annotation, Frame gewinnt) -->
        <section class="container intro-block">
          <dl class="info-overview">
            {specs.map((s) => (
              <div class="info-overview__row">
                <dt class="t-titel info-overview__label">{s.label}</dt>
                <dd class:list={["t-titel", "info-overview__value", { "info-overview__value--moos": s.tone === "moos" }]}>
                  {s.value.map((line) => <span class="info-overview__line">{line}</span>)}
                </dd>
              </div>
            ))}
          </dl>
          <div class="intro-text">
            {introParas.map((p) => <p class="t-body">{p}</p>)}
          </div>
        </section>

        <!-- 2. Bild-Strip („Image Carousel" 6467:72063) -->
        <section class="strip">
          <Carousel tone="dark" label="Projekt-Bildergalerie" class="strip__carousel">
            {strip.map((img) => (
              <li class="strip__item" style={`--ratio:${img.ratio}`}>
                <img src={img.src} alt={img.alt} loading="lazy" />
              </li>
            ))}
          </Carousel>
        </section>

        <!-- 3. Erste H4-Textblöcke (alternierend, Desktop mit leerer Bildspalte) -->
        {textBlocks1.map((b) => (
          <section class="container text-block" data-placeholder={b.placeholder}>
            <div class="text-block__text">
              <h2 class="t-h4 text-block__heading">{b.heading}</h2>
              <p class="t-body">{b.body}</p>
            </div>
            <div class="text-block__placeholder" aria-hidden="true"></div>
          </section>
        ))}

        <!-- 4. Full-Bleed Bild („Image" 6410:37083) -->
        <section class="full-image">
          <img src={fullImage.src} alt={fullImage.alt} loading="lazy" />
        </section>

        <!-- 5. Zweite H4-Textblöcke -->
        {textBlocks2.map((b) => (
          <section class="container text-block" data-placeholder={b.placeholder}>
            <div class="text-block__text">
              <h2 class="t-h4 text-block__heading">{b.heading}</h2>
              <p class="t-body">{b.body}</p>
            </div>
            <div class="text-block__placeholder" aria-hidden="true"></div>
          </section>
        ))}

        <!-- 6. Bild-Collage („Collage S 1" 6410:37088) -->
        <section class="collage">
          <div class="collage__main">
            <img src={collage.main.src} alt={collage.main.alt} loading="lazy" />
          </div>
          <div class="collage__side">
            <div class="collage__cell">
              <img src={collage.topRight.src} alt={collage.topRight.alt} loading="lazy" />
            </div>
            <div class="collage__cell">
              <img src={collage.bottomRight.src} alt={collage.bottomRight.alt} loading="lazy" />
            </div>
          </div>
        </section>

        <!-- 7. Bild-Platzhalter („horizontal-spacing-fill", h 240) -->
        <section class="container wide-image">
          <img src={wideImage.src} alt={wideImage.alt} loading="lazy" />
        </section>

        <!-- 8. Abschluss-Textblock -->
        <section class="container text-block" data-placeholder={resultBlock.placeholder}>
          <div class="text-block__text">
            <h2 class="t-h4 text-block__heading">{resultBlock.heading}</h2>
            <p class="t-body">{resultBlock.body}</p>
          </div>
          <div class="text-block__placeholder" aria-hidden="true"></div>
        </section>
      </article>

      <!-- RELATED ARTICLES — Frame 6410:37158 / 6410:37217 / 6319:53693 (nature) -->
      <section class="related">
        <div class="container related__inner">
          <p class="t-titel related__title">
            <span class="related__dot" aria-hidden="true"></span>Das könnte Ihnen auch gefallen
          </p>
          <Carousel tone="dark" label="Verwandte Projekte" perMobile={1} perTablet={2} perDesktop={3} class="related__carousel">
            {related.map((r) => (
              <li>
                <Card href={r.href} image={r.img} alt={r.title} eyebrow={r.eyebrow} title={r.title} ratio="landscape" />
              </li>
            ))}
          </Carousel>
        </div>
      </section>

      <!-- KONTAKT — Frame „Kontakt" 6410:37100 / 6319:53923 / 5660:19707 (Cta, weiß) -->
      <Cta
        bg="default"
        over="Services"
        heading="Sie haben eine Vision für Ihr individuelles Raumkonzept?"
      />
    </main>

    <Footer />

    <style>
      /* ============ HERO ============ */
      /* Frame: pt XXL, gap ML zwischen Intro-Text und Bild; Bild full-bleed. */
      .hero {
        display: flex;
        flex-direction: column;
        gap: var(--gap-ml);
        padding-top: var(--gap-xxl);
        background: var(--white);
      }
      .hero__text {
        display: flex;
        flex-direction: column;
        gap: var(--gap-m);
        max-width: var(--text-max); /* 652 / 927 / 1056 */
      }
      .breadcrumb { color: var(--grey); display: flex; flex-wrap: wrap; align-items: center; }
      .bc-link { color: var(--grey); }
      .bc-current { color: var(--text); }
      .bc-sep { color: var(--grey); }
      .hero__image { width: 100%; height: 585px; } /* image-vertical Mobil 585 */
      .hero__image img { width: 100%; height: 100%; object-fit: cover; }

      /* ============ ARTIKEL ============ */
      /* Frame: pt XXL, pb XL, gap XL zwischen den Blöcken. */
      .artikel {
        display: flex;
        flex-direction: column;
        gap: var(--gap-xl);
        padding-block: var(--gap-xxl) var(--gap-xl);
        background: var(--white);
      }

      /* 1. Info Overview + Intro — Mobil/Tablet gestapelt, gap ML. */
      .intro-block {
        display: flex;
        flex-direction: column;
        gap: var(--gap-ml);
      }
      .info-overview {
        display: flex;
        flex-direction: column;
        gap: var(--gap-xs);
        max-width: 550px; /* component/width/text-small-max-Bezug, Frame max 550 */
      }
      .info-overview__row { display: flex; flex-direction: column; }
      .info-overview__label { color: var(--grey); }
      .info-overview__value { color: var(--text); display: flex; flex-direction: column; }
      .info-overview__value--moos { color: var(--moos); }
      .info-overview__line { display: block; }
      .intro-text {
        display: flex;
        flex-direction: column;
        gap: var(--gap-xs);
        max-width: var(--text-max);
      }
      .intro-text .t-body { color: var(--text); }

      /* 2. Bild-Strip — horizontaler Scroll-Streifen, feste Höhe 240. */
      .strip__item {
        flex: 0 0 auto;
        height: 240px;
        aspect-ratio: var(--ratio);
      }
      .strip__item img { width: 100%; height: 100%; object-fit: cover; }
      /* Streifen linksbündig; auf Desktop rechtsbündig (Frame justify-end). */
      .strip__carousel :global(.carousel__track) { align-items: center; }

      /* 3./5./8. H4-Textblöcke — Mobil/Tablet nur Text (Bildspalte aus). */
      .text-block {
        display: flex;
        align-items: center;
        gap: var(--gutter);
      }
      .text-block__text {
        flex: 1 1 0;
        display: flex;
        flex-direction: column;
        gap: var(--gap-xs);
        max-width: var(--text-max);
      }
      .text-block__heading { color: var(--text); }
      .text-block .t-body { color: var(--text); }
      /* Leere Bild-Platzhalterspalte: nur Desktop sichtbar. */
      .text-block__placeholder { display: none; }

      /* 4. Full-Bleed Bild — image-vertical (585 Mobil). */
      .full-image { width: 100%; height: 585px; }
      .full-image img { width: 100%; height: 100%; object-fit: cover; }

      /* 6. Bild-Collage — Mobil: hohe Spalte + zwei gestapelte; Abstand spacing/L. */
      .collage {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--gap-l);
        padding-inline: var(--gap-l);
      }
      .collage__main { flex: 1 1 0; align-self: stretch; }
      .collage__main img { width: 100%; height: 100%; object-fit: cover; }
      .collage__side {
        flex: 1 1 0;
        display: flex;
        flex-direction: column;
        gap: var(--gap-l);
      }
      .collage__cell { aspect-ratio: 300 / 200; }
      .collage__cell img { width: 100%; height: 100%; object-fit: cover; }

      /* 7. Einzel-Bild-Platzhalter im Margin (h 240). */
      .wide-image { height: 240px; }
      .wide-image img { width: 100%; height: 100%; object-fit: cover; }

      /* ============ RELATED ARTICLES (nature) ============ */
      /* Frame: nature-BG, pt XXL, pb XL; Titel mit Punkt; 3 Karten + Punkte-Nav. */
      .related {
        background: var(--nature);
        padding-block: var(--gap-xxl) var(--gap-xl);
      }
      .related__inner {
        display: flex;
        flex-direction: column;
        gap: var(--gap-sm);
      }
      .related__title { display: flex; align-items: center; gap: var(--gap-xs); color: var(--grey); }
      .related__dot { width: 16px; height: 16px; border-radius: 50%; background: var(--bronze); flex: none; }
      /* Figma Related-Karte: Bild-Seitenverhältnis 400/300 (4:3), nicht Card-Default 16:10. */
      .related__carousel :global(.card--landscape .card__media) { aspect-ratio: 4 / 3; }
      /* Karten-Titel im Carousel als H4 (Frame: Montserrat Medium 20/30), Card nutzt t-h5. */
      .related__carousel :global(.card__title) { font-size: 20px; line-height: 30px; }

      /* ============ Breakpoints (kanonisch 701 / 992) ============ */
      @media (min-width: 701px) {
        .hero__image { height: 500px; }      /* image-vertical Tablet 500 */
        .full-image { height: 500px; }
        .wide-image { height: 240px; }        /* image-horizontal Tablet 500 → Platzhalter bleibt 240 (Frame) */
      }

      @media (min-width: 992px) {
        .hero__image { height: 700px; }       /* image-vertical Desktop 700 */
        .full-image { height: 700px; }

        /* Info Overview + Intro: zwei fillende Spalten (Annotation „Fill container", gap ML). */
        .intro-block { flex-direction: row; align-items: flex-start; gap: var(--gap-ml); }
        .info-overview { flex: 1 1 0; max-width: none; }
        .intro-text { flex: 1 1 0; }

        /* H4-Textblöcke: Text + leere Bildspalte (alternierend), gap gutter. */
        .text-block__placeholder {
          display: block;
          flex: 1 1 0;
          align-self: stretch;
          background: var(--nature);
        }
        .text-block[data-placeholder="left"] .text-block__text { order: 2; }
        .text-block[data-placeholder="left"] .text-block__placeholder { order: 1; }
      }
    </style>
  </body>
</html>
