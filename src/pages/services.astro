---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import Cta from "../components/Cta.astro";

// Hero-Filter (Schnellsprung-Chips) — Franzi: "Filter Option = Auswahl → User soll direkt
// zur jeweiligen Kategorie gescrollt werden." Anker-Links erledigen genau das.
const chips = [
  { label: "Komplettes Wohnkonzept", href: "#komplettloesung" },
  { label: "Gardinen & Rollos", href: "#gardinen-rollos" },
  { label: "Stoffe", href: "#stoffe" },
  { label: "Boden", href: "#boden" },
  { label: "Wand", href: "#wand" },
  { label: "Einrichtung", href: "#einrichtung" },
];

// PLATZHALTER-Linkliste (Inhaber-Entscheidung 2026-05-31: "Platzhalter wie Figma").
// Im Figma-Frame stehen bei ALLEN Kategorien identisch die Gardinen-Unterpunkte —
// echte Teilleistungen für Stoffe/Boden/Wand/Einrichtung folgen später von Franzi.
const placeholderLinks = [
  { label: "Alle Gardinen & Rollos anzeigen", href: "/services/gardinen-rollos" },
  { label: "Vorhänge", href: "#" },
  { label: "Raffrollos", href: "#" },
  { label: "Flächenvorhänge", href: "#" },
  { label: "Gardinenstangen", href: "#" },
  { label: "Rollos", href: "#" },
  { label: "Lamellenvorhänge", href: "#" },
];

// Einzelleistungen — 5 Kategorien. Reihenfolge & Texte aus Figma V4 (12307:37398).
// Kategorie-Beschreibungen sind echte Inhalte; die 7 Card-Links sind Figma-Platzhalter
// (Kat. 1 mit echten Gardinen-Zielen, Kat. 2–5 vorerst dieselbe Platzhalterliste).
// Bilder sind Platzhalter (vorhandene Assets), bis echte Kategorie-Bilder vorliegen.
const kategorien = [
  {
    id: "gardinen-rollos",
    titel: "Gardinen & Rollos",
    text: "Ob eleganter Sichtschutz, effektive Verdunkelung oder stilvolles Design – wir fertigen maßgeschneiderte Gardinen und Vorhänge, die Ihren Raum perfekt ergänzen.",
    img: "/images/home/project-1.jpg",
    links: [
      { label: "Alle Gardinen & Rollos anzeigen", href: "/services/gardinen-rollos" },
      { label: "Vorhänge", href: "/services/gardinen-rollos#vorhaenge" },
      { label: "Raffrollos", href: "/services/gardinen-rollos#raffrollos" },
      { label: "Flächenvorhänge", href: "/services/gardinen-rollos#flaechenvorhaenge" },
      { label: "Gardinenstangen", href: "/services/gardinen-rollos#gardinenstangen" },
      { label: "Rollos", href: "/services/gardinen-rollos#rollos" },
      { label: "Lamellenvorhänge", href: "/services/gardinen-rollos#lamellenvorhaenge" },
    ],
  },
  {
    id: "stoffe",
    titel: "Stoffe",
    text: "Hochwertige Stoffe setzen Akzente, verleihen Räumen Wärme und unterstreichen Ihre persönliche Einrichtung.",
    img: "/images/komplettloesung/card2.png",
    links: placeholderLinks,
  },
  {
    id: "boden",
    titel: "Boden",
    text: "Ob Parkett, Teppich oder Designbelag – wir finden passenden Bodenbelag, der Optik und Komfort verbindet.",
    img: "/images/home/project-2.jpg",
    links: placeholderLinks,
  },
  {
    id: "wand",
    titel: "Wand",
    text: "Farben, Tapeten oder kreative Techniken – wir gestalten Wände, die Räume aufwerten und Atmosphäre schaffen.",
    img: "/images/komplettloesung/card3.png",
    links: placeholderLinks,
  },
  {
    id: "einrichtung",
    titel: "Einrichtung",
    text: "Von Möbel bis Dekoration – wir gestalten individuelle Einrichtungskonzepte, die Ästhetik und Funktion perfekt vereinen.",
    img: "/images/komplettloesung/card1.png",
    links: placeholderLinks,
  },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Services — Maßgeschneiderte Raumgestaltung | ADLER Wohndesign</title>
    <meta name="description" content="Die Leistungen von ADLER Wohndesign: von der Komplettlösung bis zu Einzelleistungen – Gardinen & Rollos, Stoffe, Einrichtung, Boden und Wand. Passgenau für Ihre Räume." />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <Header />

    <main>
      <!-- HERO -->
      <section class="hero">
        <div class="container hero__text">
          <p class="t-titel hero__over">Services</p>
          <h1 class="t-h1">Maßgeschneiderte Raumgestaltung – flexibel und professionell</h1>
          <p class="t-body hero__lead">Wir gestalten Räume, die wirklich zu Ihnen passen – vom ersten Gespräch bis zur fertigen Umsetzung. Ob einzelne Leistung oder komplettes Raumkonzept, ob Gardinen, Boden, Wand oder Einrichtung – wir bieten Ihnen passgenaue Konzepte für Ihre Räume. Sie entscheiden den Umfang, wir kümmern uns um die perfekte Ausführung. Mit Fachwissen, handwerklicher Präzision und über 85 Jahren Erfahrung. Perfekt.</p>
          <div class="hero__filter">
            <p class="t-small hero__filter-label">Scrolle zu</p>
            <ul class="chips">
              {chips.map((c) => (<li><a class="chip t-small" href={c.href}>{c.label}</a></li>))}
            </ul>
          </div>
        </div>
        <!-- Franzi: Hero ist ein Video ("fertige Komplettlösungen, Emotionen aufbauen").
             Video-Datei folgt → bis dahin Poster-Bild als Fallback (kein <source> = nur Poster sichtbar). -->
        <div class="hero__image">
          <video
            class="hero__video"
            poster="/images/home/hero.jpg"
            autoplay
            muted
            loop
            playsinline
            aria-label="Maßgeschneiderte Raumgestaltung von ADLER Wohndesign"
          >
            <!-- TODO: echte Video-Quelle eintragen, sobald von Franzi geliefert:
            <source src="/videos/services-hero.mp4" type="video/mp4" /> -->
          </video>
        </div>
      </section>

      <!-- KOMPLETTLÖSUNG -->
      <section class="block container" id="komplettloesung">
        <p class="t-titel block__over">Komplettlösung</p>
        <h2 class="block__head kat-h">Ganzheitliche Wohnkonzepte – Alles aus einer Hand</h2>
        <p class="t-body block__lead">Ob einzelnes Zimmer, ganze Wohnung oder komplettes Haus – wir gestalten Ihre Räume von der ersten Idee bis zur letzten Handbewegung. Mit unserer Komplettlösung übernehmen wir alles: Beratung, Planung, Materialauswahl und Umsetzung. Ein Team, ein Ansprechpartner, ein perfektes Ergebnis. Sie lehnen sich zurück – wir machen den Rest.</p>
        <p class="t-body block__hint">So sieht unser Rundum-Service aus:</p>
        <Button href="/komplettloesung">Komplettlösung entdecken</Button>
      </section>

      <!-- EINZELLEISTUNGEN -->
      <section class="block block--einzel container" id="einzelleistungen">
        <div class="block__intro">
          <p class="t-titel block__over">Teilleistungen</p>
          <h2 class="block__head kat-h">Individuelle Einzelleistungen</h2>
          <p class="t-body block__lead">Nicht immer ist eine Komplettlösung erforderlich. Sie benötigen eine Farbberatung, neue Vorhänge oder einen effektiven Sicht- und Sonnenschutz? Wir bieten Ihnen gezielte Einzelleistungen, die sich exakt an Ihren Wünschen orientieren. Ob kleines Detail oder gezielte Anpassung – Sie entscheiden, wir setzen es fachgerecht um.</p>
        </div>

        <div class="kategorien">
          {kategorien.map((k) => (
            <article class="kat" id={k.id}>
              <div class="kat__head">
                <h3 class="kat-h kat__title">{k.titel}</h3>
                <p class="t-body kat__text">{k.text}</p>
              </div>
              <div class="kat__body">
                <div class="kat__media"><img src={k.img} alt={k.titel} loading="lazy" /></div>
                <ul class="linklist">
                  {k.links.map((l) => (
                    <li>
                      <a class="linkrow" href={l.href}>
                        <span class="t-h4 linkrow__label">{l.label}</span>
                        <span class="linkrow__btn"><Icon name="arrow_upward" size={32} class="linkrow__arrow" /></span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- KONTAKT -->
      <Cta
        bg="default"
        heading="Sie haben Fragen oder sind sich nicht sicher, wo Sie anfangen sollen? Wir helfen Ihnen."
        lead="Manchmal weiß man, was man möchte – aber nicht genau wie. Genau dafür sind wir da. Wir nehmen uns die Zeit, Ihre Wünsche zu verstehen, und zeigen Ihnen, welche Leistungen wirklich zu Ihrem Raum und Ihrem Budget passen. Unverbindlich, persönlich und ohne Druck."
        buttonLabel="Jetzt Beratung vereinbaren"
      />
    </main>

    <Footer />

    <style>
      /* Kategorie-/Block-Überschrift: Figma = Montserrat Medium (size/H2), NICHT Playfair.
         Größe über t-h3-Skala (passt zur Frame-Optik); Familie/Gewicht aus design_context. */
      .kat-h {
        font-family: var(--font-body);
        font-weight: 500;
        font-size: 28px; line-height: 40px; letter-spacing: 0;
        color: var(--text);
      }
      @media (min-width: 701px) { .kat-h { font-size: 32px; line-height: 46px; } }
      @media (min-width: 992px) { .kat-h { font-size: 36px; line-height: 52px; } }

      /* ---- HERO ---- */
      .hero { padding-top: var(--pad-section); }
      .hero__text { display: flex; flex-direction: column; gap: var(--gap-m); max-width: 1136px; }
      .hero__over { color: var(--grey); }
      .hero__lead { max-width: 75ch; }
      .hero__filter { display: flex; flex-direction: column; gap: var(--gap-xs); }
      .hero__filter-label { color: var(--grey); }
      .chips { display: flex; flex-wrap: wrap; gap: var(--gap-xs); }
      .chip {
        display: inline-flex; align-items: center;
        border: 1px solid var(--light-grey);
        border-radius: 40px;
        padding: 10px 22px;
        color: var(--text);
        transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
      }
      .chip:hover { background: var(--moos); color: var(--white); border-color: var(--moos); }
      .hero__image { margin-top: var(--gap-ml); width: 100%; height: clamp(240px, 40vw, 700px); }
      .hero__video { width: 100%; height: 100%; object-fit: cover; background: var(--light-grey); }

      /* ---- BLOCK (Komplettlösung / Einzelleistungen) ---- */
      .block { padding-block: var(--pad-section) var(--gap-xl); display: flex; flex-direction: column; gap: var(--gap-xs); max-width: 1136px; }
      .block--einzel { max-width: none; }
      .block__over { color: var(--grey); }
      .block__head { margin-bottom: var(--gap-xs); }
      .block__lead { color: var(--text); max-width: 88ch; }
      .block__hint { color: var(--grey); margin-top: var(--gap-s); }
      .block .btn { align-self: flex-start; margin-top: var(--gap-s); }
      .block__intro { display: flex; flex-direction: column; gap: var(--gap-xs); max-width: 1136px; }
      .block__intro .block__head { margin-bottom: var(--gap-xs); }

      /* ---- KATEGORIEN ---- */
      .kategorien { display: flex; flex-direction: column; gap: var(--gap-xl); margin-top: var(--gap-xl); }
      .kat { display: flex; flex-direction: column; gap: var(--gap-m); scroll-margin-top: 120px; }
      .kat__head { display: flex; flex-direction: column; gap: var(--gap-xs); max-width: 88ch; }
      .kat__text { color: var(--text); }
      .kat__body { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gutter) var(--gap-xl); align-items: start; }
      .kat__media { height: clamp(280px, 34vw, 532px); }
      .kat__media img { width: 100%; height: 100%; object-fit: cover; }

      /* Card-Links (Figma "Card Link"): Zeile mit Label (H4) + Pfeil-Button (32), Padding px sm/py xs, kein Rahmen */
      .linklist { display: flex; flex-direction: column; }
      .linkrow {
        display: flex; align-items: center; justify-content: space-between; gap: var(--gap-s);
        padding: var(--gap-xs) var(--gap-sm);
        color: var(--text);
        transition: background 0.2s ease;
      }
      .linkrow__label { color: var(--text); transition: color 0.2s ease; }
      .linkrow__btn { display: grid; place-items: center; flex: none; transition: transform 0.25s ease; }
      /* Figma: arrow_upward 90° gedreht = Pfeil nach rechts. Farbe bronze (Akzent, wie Screenshots). */
      .linkrow :global(.linkrow__arrow) { transform: rotate(90deg); color: var(--bronze); }
      .linkrow:hover .linkrow__label { color: var(--bronze); }
      .linkrow:hover .linkrow__btn { transform: translateX(4px); }

      /* ---- Responsive ---- */
      @media (max-width: 700px) {
        .kat__body { grid-template-columns: 1fr; gap: var(--gap-m); }
        .kat__media { height: clamp(200px, 56vw, 300px); }
        .linkrow { padding-inline: 0; }
      }
    </style>
  </body>
</html>
