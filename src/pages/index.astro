---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

// Projekt-Aufbau — Akkordeon (Texte 2–5 folgen aus Figma)
const aufbau = [
  {
    titel: "1. Beratung",
    text: "In unserem ersten Schritt im Projekt mit Ihnen suchen wir alle Informationen zusammen. Wir lernen Sie und Ihre Wünsche und Vorstellungen im Projekt kennen und was Sie erreichen wollen. Wir beziehen in die Überlegungen den Stil, technische und gestalterische Möglichkeiten, bauliche Änderungen, funktionale Anforderungen und das Budget mit ein.",
  },
  { titel: "2. Raumanalyse", text: "Inhalt folgt." },
  { titel: "3. Design- und Raumkonzeption", text: "Inhalt folgt." },
  { titel: "4. Angebot", text: "Inhalt folgt." },
  { titel: "5. Umsetzung", text: "Inhalt folgt." },
];

// Projekt-Vorschau (Platzhalter-Inhalte aus Figma)
const proj = { img1: "/images/home/project-1.jpg", img2: "/images/home/project-2.jpg", cat: "Penthouse Berlin", titel: "Leichtes Raum & Licht Konzept" };

// Kundenstimmen — echt, von marco kuratiert & sortiert (Quellen: Google 4,9★/48 + ProvenExpert 4,95★/190)
// Lange Bewertungen für den Slider auf einen wortgetreuen Auszug gekürzt; Volltexte: /Bewertungen/Schoenste_Bewertungen_sortiert.md (später ins CMS)
const reviews = [
  { name: "Christine Wohs", quelle: "Google", text: "Wir sind rundum begeistert von ADLER Wohndesign! Besonders hervorheben möchten wir die großartige Beratung durch Frau Vogt, die uns mit ihrem feinen Gespür für Farben und Design perfekt unterstützt hat. Ein tolles Team, das mit viel Kompetenz und Herzblut arbeitet. Klare Empfehlung!" },
  { name: "Andrea Hofmeier", quelle: "Google", text: "Wir sind vollends begeistert über die Zusammenarbeit mit der Firma Adler. Freundlich, kompetent, zuverlässig und eine hervorragende Umsetzung des Auftrags. Von der Beratung bis zum Verlassen des Objekts: perfekt." },
  { name: "Raphael Terium", quelle: "Google", text: "Der perfekte Ort, um Ihren Traum zu verwirklichen. Die Mitarbeiter sind alle sehr freundlich und hochqualifiziert und haben ein ausgezeichnetes Auge fürs Detail, das die Wünsche der Kunden widerspiegelt. Die Montage der Vorhänge verlief schnell, freundlich und sauber." },
  { name: "Sabine Widera", quelle: "Google", text: "Einfach nur atemberaubend und absolut empfehlenswert!! Die Stoffauswahl ist großartig, hochwertig und inspirierend. Das Ergebnis ist einfach nur wunderschön und die Räume nicht mehr wiederzukennen." },
  { name: "Paul Purrmann", quelle: "Google", text: "Wir sind absolut begeistert von der Arbeit von Adler Wohndesign! Bei uns wurde im Schlafzimmer ein neuer Vorhang eingebaut und das Ergebnis ist einfach perfekt. Man merkt sofort, dass hier jemand mit Leidenschaft und Kompetenz am Werk ist." },
  { name: "Frau Heinelt", quelle: "ProvenExpert", text: "Ich bin SEHR zufrieden und werde auch zukünftig sehr gerne meine Wünsche perfekt von ADLER Wohndesign umsetzen lassen. Besser geht es nicht: persönliche Beratung, perfekte Umsetzung und sehr saubere, professionelle Arbeit." },
  { name: "Carmen Ernst", quelle: "Google", text: "Ich bin begeistert. Was das für eine tolle Veränderung in unserem Wohnzimmer ist! Das hätte ich nicht gedacht, dass es so cool wirkt. Vielen Dank für die nette und vor allem profimäßige Beratung sowie Ausführung." },
  { name: "Familie Albrecht", quelle: "Google", text: "Der Chef, Herr Drewitz, hat ein Auge für Schönheit und hat uns toll beraten. Die Montage war ausgezeichnet und sehr sorgfältig. Wir sind sehr zufrieden – unsere neue Wohnung sieht mit den Vorhängen sehr hochwertig aus." },
  { name: "Carina Olszewski", quelle: "Google", text: "Wir sind absolut begeistert von den Maler- und Tapezierarbeiten in unserem Wohnzimmer. Jedes Detail wurde mit größter Sorgfalt und Präzision ausgeführt. Wir können Adler Wohndesign wärmstens weiterempfehlen!" },
  { name: "Jan Asmus", quelle: "Google", text: "Meine Frau und ich haben eine neue Penthouse-Wohnung gekauft und Adler Wohndesign hat uns geholfen, diese in unsere persönliche Traumwohnung zu verwandeln. Wir freuen uns jeden Tag, wie schön wir es haben, und unsere Gäste betonen die angenehme Atmosphäre." },
  { name: "Melissa Pond", quelle: "Google", text: "Vielen herzlichen Dank an das wunderbare Team von Adler Wohndesign. Mit viel Geduld, Hingabe, Professionalität und Feingefühl wurde mein Projekt realisiert. Das Ergebnis sind Räume, die zum Wohnen einladen. Uneingeschränkt empfehlenswert!" },
  { name: "J. Bojarski", quelle: "Google", text: "Ein „Raumausstatter“ für alle Belange, zu 100 % empfehlenswert! Von hervorragender Beratung bis zu handwerklichem Geschick war alles dabei. Schön, dass es noch solche Handwerksbetriebe gibt mit solch einem breiten Portfolio." },
  { name: "Jean-Pierre Andreae", quelle: "ProvenExpert", text: "Man fühlt sich von der ersten Idee bis zur Abnahme der Leistung perfekt aufgehoben. Die Akkuratesse bei der Umsetzung, die Sauberkeit und das Endergebnis – alles Grund genug, das Adler-Team weiterzuempfehlen!" },
  { name: "Frau von Weiler", quelle: "ProvenExpert", text: "Eine rundum zufriedenstellende Erfahrung, vom Erstkontakt im Laden bis zum Aufhängen der Vorhänge zu Hause. Kompetente Beratung, sehr professionelles Team, und dazu auch noch nett, zugänglich, offen und freundlich!" },
  { name: "Jennifer Kirschke", quelle: "Google", text: "Kompetente, überaus freundliche Beratung. Wunderschöne Materialien, jahrelange Erfahrung, ein sehr hilfsbereites, sympathisches Team. 100 % Weiterempfehlung. Vielen Dank!" },
  { name: "Eike Garbers", quelle: "Google", text: "Ich kann mein Glück kaum in Worte fassen! Fünf Sterne reichen nicht! Frau Vogt hat unglaublich schnell verstanden, was ich mir wünsche, und ein Farbkonzept entwickelt, das mich vollkommen von den Socken haut. 1000 Dank für diesen perfekten Job!" },
  { name: "Christine Schramm", quelle: "Google", text: "Die Kommunikation ist verlässlich, die Qualität herausragend – und trotzdem umfängt einen sofort ein familiäres Gefühl, als sei man zu Hause. Ich freue mich jeden Tag an dem durchdachten Design. 6 von 5 Sternen ♥️" },
  { name: "Barbara Platzer", quelle: "Google", text: "Fantastische, freundliche und effiziente Beratung. Kimberly und ihr gesamtes Team sind sehr engagiert und sorgen für einen reibungslosen Ablauf! Absolut empfehlenswert." },
  { name: "Christoph Rotstein", quelle: "ProvenExpert", text: "Wir haben für unser Wohnzimmer Vorhänge anfertigen lassen. Der gesamte Ablauf, von der Beratung bei der Auswahl des Stoffs und der Farbe bis zur anschließenden Montage vor Ort: Alles perfekt und so wie man sich als Kunde es wünscht!" },
  { name: "Frau Feuerherdt", quelle: "ProvenExpert", text: "Wir sind „Wiederholungstäter“ und schätzen die klare, zielorientierte Fachberatung. Das gesamte Team ist sehr freundlich, die Umsetzung erfolgt zügig und professionell. Wir wüssten nicht, was besser gehen sollte!" },
];

---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ADLER Wohndesign — Raumausstatter & Innenarchitektur in Berlin-Charlottenburg</title>
    <meta name="description" content="ADLER Wohndesign: Meisterbetrieb seit über 85 Jahren. Ganzheitliche Raumkonzepte aus Berlin-Charlottenburg – von der ersten Idee bis zum letzten Detail." />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <Header />

    <main>
      <!-- HERO -->
      <section class="hero" aria-labelledby="hero-title">
        <img class="hero__img" src="/images/home/hero.jpg" alt="ADLER Wohndesign Showroom in Berlin-Charlottenburg" fetchpriority="high" />
        <div class="hero__overlay" aria-hidden="true"></div>
        <div class="container hero__content">
          <p class="t-titel hero__over">Adler Wohndesign — Raumausstatter &amp; Innenarchitektur-Studio in Berlin</p>
          <h1 id="hero-title" class="t-h1">Wir kreieren Ihren Wohlfühlort – perfekt.</h1>
          <a class="btn" href="/kontakt">Mein Projekt starten</a>
        </div>
      </section>

      <!-- SERVICES (Statement) -->
      <section class="services container">
        <p class="t-titel services__over">Unser Service</p>
        <p class="t-h3 services__text">Wir sind ADLER Wohndesign. Meisterbetrieb mit über 85 Jahren Erfahrung – für Wohnkonzepte, die wirklich passen. Für echtes Handwerk und bleibendes Wohlfühlen in Ihrem Zuhause. Wir begleiten Sie von der ersten Idee bis zum letzten Detail – wir übernehmen alles. Für Sie.</p>
        <a class="btn" href="/komplettloesung">Mein Projekt starten</a>
      </section>

      <!-- PROJEKT-VORSCHAU -->
      <section class="projects container" aria-label="Projekte">
        <div class="projects__row projects__row--a">
          <a class="pcard" href="/projekte">
            <div class="pcard__media"><img src={proj.img1} alt={`${proj.cat} – ${proj.titel}`} loading="lazy" /></div>
            <p class="t-small pcard__cat">{proj.cat}</p>
            <p class="t-h5 pcard__title">{proj.titel}</p>
          </a>
          <a class="pcard" href="/projekte">
            <div class="pcard__media"><img src={proj.img2} alt={`${proj.cat} – ${proj.titel}`} loading="lazy" /></div>
            <p class="t-small pcard__cat">{proj.cat}</p>
            <p class="t-h5 pcard__title">{proj.titel}</p>
          </a>
        </div>
        <div class="projects__row projects__row--b">
          <a class="pcard" href="/projekte">
            <div class="pcard__media"><img src={proj.img2} alt={`${proj.cat} – ${proj.titel}`} loading="lazy" /></div>
            <p class="t-small pcard__cat">{proj.cat}</p>
            <p class="t-h5 pcard__title">{proj.titel}</p>
          </a>
          <a class="pcard" href="/projekte">
            <div class="pcard__media"><img src={proj.img1} alt={`${proj.cat} – ${proj.titel}`} loading="lazy" /></div>
            <p class="t-small pcard__cat">{proj.cat}</p>
            <p class="t-h5 pcard__title">{proj.titel}</p>
          </a>
        </div>
      </section>

      <!-- PROJEKT AUFBAU -->
      <section class="aufbau container">
        <div class="aufbau__intro">
          <p class="t-titel aufbau__over"><span class="dot" aria-hidden="true"></span>Unsere Expertise</p>
          <p class="t-h4 aufbau__lead">Wir bieten einen neuen Standard für Raumgestaltung in Berlin – persönlich, vielseitig und ohne Aufwand für Sie. Von einzelnen Leistungen wie Lichtkonzepten, Maßgardinen oder Bodengestaltung bis zum vollständigen Rundum-Paket. Was Sie beauftragen, liegt ganz bei Ihnen.</p>
        </div>
        <div class="aufbau__list">
          {aufbau.map((item, i) => (
            <details name="aufbau" open={i === 0}>
              <summary>
                <span class="t-h4">{item.titel}</span>
                <svg class="chev" viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="6 9 12 15 18 9" /></svg>
              </summary>
              <div class="aufbau__body"><p class="t-body">{item.text}</p></div>
            </details>
          ))}
        </div>
      </section>

      <!-- DAS SIND WIR -->
      <section class="team">
        <div class="team__media">
          <img src="/images/home/team.jpg" alt="Das Team von ADLER Wohndesign im Showroom" loading="lazy" />
        </div>
        <div class="team__text">
          <p class="t-titel">Das sind wir</p>
          <h2 class="t-h3 team__head">Lernen Sie uns kennen</h2>
          <p class="t-body">Hinter jedem Projekt steht ein Team mit Leidenschaft und Expertise für Raumgestaltung. Lernen Sie die Menschen hinter ADLER kennen, besuchen Sie unseren Showroom in Charlottenburg – und entdecken Sie, was uns bis heute antreibt.</p>
          <a class="btn" href="/ueber-uns">Mehr über uns</a>
        </div>
      </section>

      <!-- KUNDENSTIMMEN -->
      <section class="reviews container" aria-label="Kundenstimmen">
        <div class="reviews__top">
          <div class="reviews__head">
            <p class="t-titel reviews__over"><span class="dot" aria-hidden="true"></span>Kundenstimmen</p>
            <h2 class="t-h4 reviews__title">Das sagen unsere Kunden zu uns</h2>
            <p class="reviews__rating"><span class="rcard__stars" aria-hidden="true">★★★★★</span> <strong>4,95/5</strong> auf ProvenExpert · <strong>4,9/5</strong> auf Google</p>
          </div>
          <div class="reviews__nav">
            <button class="rev-btn" type="button" data-rev="prev" aria-label="Vorherige Bewertungen">‹</button>
            <button class="rev-btn" type="button" data-rev="next" aria-label="Nächste Bewertungen">›</button>
          </div>
        </div>
        <ul class="reviews__track" id="reviewsTrack">
          {reviews.map((r) => (
            <li class="rcard">
              <p class="rcard__stars" aria-label="Fünf von fünf Sternen">★★★★★</p>
              <div class="rcard__person">
                <p class="t-h5 rcard__name">{r.name}</p>
                <p class="t-small rcard__src">{r.quelle}</p>
              </div>
              <p class="t-body rcard__text">{r.text}</p>
            </li>
          ))}
        </ul>
      </section>
      <script>
        // Kundenstimmen-Karussell: Pfeile scrollen den Track
        const revTrack = document.getElementById("reviewsTrack");
        if (revTrack) {
          const step = () => Math.min(revTrack.clientWidth * 0.85, 480);
          document.querySelectorAll("[data-rev]").forEach((btn) => {
            btn.addEventListener("click", () => {
              const dir = btn.getAttribute("data-rev") === "next" ? 1 : -1;
              revTrack.scrollBy({ left: dir * step(), behavior: "smooth" });
            });
          });
        }
      </script>

      <!-- KONTAKT -->
      <section class="kontakt">
        <div class="container kontakt__inner">
          <p class="t-titel kontakt__over">Kontakt</p>
          <h2 class="t-h3 kontakt__head">Ihr Wohlfühlort wartet – lassen Sie uns gemeinsam starten.</h2>
          <p class="t-body kontakt__lead">Rufen Sie uns an oder schreiben Sie uns, und wir vereinbaren einen Termin im Atelier ADLER Wohndesign. Lassen Sie uns gemeinsam starten.</p>
          <a class="btn" href="/kontakt">Mein Projekt starten</a>
        </div>
      </section>

      <!-- BLOG-VORSCHAU -->
      <section class="blog" aria-label="Blog">
        <div class="container blog__head">
          <p class="t-titel blog__over">Blog</p>
          <h2 class="t-h3 blog__title">Wissen, Erfahrung und Inspiration – entdecken Sie Tipps und Neuigkeiten aus unserer Welt der Raumgestaltung.</h2>
        </div>
        <div class="blog__track">
          <a class="bcard bcard--sq" href="/blog"><img src="/images/home/blog-wassertage.jpg" alt="Wassertage" loading="lazy" /></a>
          <a class="bcard bcard--sq" href="/blog"><img src="/images/home/blog-akustik.jpg" alt="Akustikstoffe" loading="lazy" /></a>
          <a class="bcard bcard--feature" href="/blog">
            <div class="bcard__media"><img src="/images/home/blog-thumbnail.jpg" alt="Gesellenprüfung zur Raumausstatterin Kimberly Fischer" loading="lazy" /></div>
            <div class="bcard__link">
              <div class="bcard__header"><span class="t-titel">Aktuelles</span><span class="t-small">Aktueller Artikel</span></div>
              <p class="t-h5 bcard__title">Gesellenprüfung zur Raumausstatterin Kimberly Fischer</p>
            </div>
          </a>
          <a class="bcard bcard--sq" href="/blog"><img src="/images/home/blog-wassertage.jpg" alt="Wassertage" loading="lazy" /></a>
          <a class="bcard bcard--sq" href="/blog"><img src="/images/home/blog-akustik.jpg" alt="Akustikstoffe" loading="lazy" /></a>
        </div>
      </section>
    </main>

    <Footer />

    <style>
      /* HERO */
      .hero { position: relative; min-height: clamp(540px, 86vh, 900px); display: flex; align-items: flex-end; overflow: hidden; }
      .hero__img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 38%; }
      .hero__overlay { position: absolute; inset: 0; background:
        linear-gradient(180deg, rgba(31,31,39,0.28) 0%, rgba(31,31,39,0.10) 30%, rgba(31,31,39,0.30) 60%, rgba(31,31,39,0.66) 100%); }
      .hero__content { position: relative; z-index: 1; padding-block: clamp(40px, 7vh, 96px); display: flex; flex-direction: column; gap: var(--gap-m); align-items: flex-start; color: var(--white); }
      .hero__over { color: rgba(255,255,255,0.82); max-width: 52ch; }
      .hero .t-h1 { color: var(--white); max-width: 18ch; }

      /* SERVICES */
      .services { padding-block: var(--pad-section); display: flex; flex-direction: column; align-items: center; gap: var(--gap-m); text-align: center; }
      .services__text { color: var(--text); max-width: 30ch; }

      /* PROJEKT AUFBAU */
      .aufbau { padding-block: var(--pad-section); display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-xl); align-items: start; }
      .aufbau__intro { display: flex; flex-direction: column; gap: var(--gap-s); max-width: 652px; }
      .aufbau__over { display: flex; align-items: center; gap: var(--gap-xs); }
      .dot { width: 12px; height: 12px; border-radius: 50%; background: var(--bronze); flex: none; }
      .aufbau__lead { color: var(--text); }
      .aufbau__list { display: flex; flex-direction: column; }
      .aufbau details { border-bottom: 1px solid var(--light-grey); }
      .aufbau summary { list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: var(--gap-s); padding-block: var(--gap-s); color: var(--text); }
      .aufbau summary::-webkit-details-marker { display: none; }
      .aufbau .chev { color: var(--bronze); flex: none; transition: transform 0.25s ease; }
      .aufbau details[open] .chev { transform: rotate(180deg); }
      .aufbau__body { padding-bottom: var(--gap-s); }
      .aufbau__body .t-body { color: var(--text); max-width: 60ch; }

      /* DAS SIND WIR */
      .team { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gap-l); align-items: center; padding-block: var(--pad-section); padding-right: var(--layout-margin); }
      .team__media { height: clamp(320px, 40vw, 700px); }
      .team__media img { width: 100%; height: 100%; object-fit: cover; }
      .team__text { display: flex; flex-direction: column; gap: var(--gap-m); max-width: 652px; }
      .team__head { color: var(--text); }

      /* KONTAKT */
      .kontakt { background: var(--moos); color: var(--white); padding-block: var(--pad-section); }
      .kontakt__inner { display: flex; flex-direction: column; align-items: center; gap: var(--gap-m); text-align: center; max-width: 760px; }
      .kontakt__over { color: rgba(255,255,255,0.7); }
      .kontakt__head, .kontakt__lead { color: var(--white); }
      .kontakt__head { max-width: 22ch; }
      .kontakt__lead { max-width: 56ch; }

      /* PROJEKT-VORSCHAU */
      .projects { padding-block: var(--pad-section); display: flex; flex-direction: column; gap: var(--gutter); }
      .projects__row { display: grid; gap: var(--gutter); }
      .projects__row--a { grid-template-columns: 2fr 1fr; }
      .projects__row--b { grid-template-columns: 1fr 2fr; }
      .pcard { display: flex; flex-direction: column; gap: 6px; color: var(--text); }
      .pcard__media { height: clamp(280px, 40vw, 600px); overflow: hidden; }
      .pcard__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
      .pcard:hover .pcard__media img { transform: scale(1.03); }
      .pcard__cat { color: var(--grey); margin-top: 8px; }
      .pcard__title { color: var(--text); }

      /* KUNDENSTIMMEN */
      .reviews { padding-block: var(--pad-section); display: flex; flex-direction: column; gap: var(--gap-m); }
      .reviews__head { display: flex; flex-direction: column; gap: var(--gap-xs); }
      .reviews__over { display: flex; align-items: center; gap: var(--gap-xs); }
      .reviews__title { color: var(--text); }
      .reviews__track { display: flex; gap: var(--gutter); overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 12px; }
      .rcard { flex: 0 0 clamp(280px, 30vw, 451px); scroll-snap-align: start; background: var(--nature); padding: var(--gap-m) var(--gap-sm); display: flex; flex-direction: column; gap: var(--gap-xs); }
      .rcard__stars { color: var(--bronze); letter-spacing: 3px; font-size: 22px; line-height: 1; }
      .rcard__name { color: var(--text); }
      .rcard__src { color: var(--grey); }
      .rcard__text { color: var(--text); }
      .reviews__top { display: flex; align-items: flex-end; justify-content: space-between; gap: var(--gap-m); }
      .reviews__rating { margin-top: var(--gap-xs); color: var(--text); font-size: 14px; }
      .reviews__rating .rcard__stars { font-size: 16px; }
      .reviews__rating strong { font-weight: 600; }
      .reviews__nav { display: flex; gap: 12px; flex: none; }
      .rev-btn { width: 48px; height: 48px; border-radius: 50%; border: 1px solid var(--light-grey); color: var(--text); font-size: 24px; line-height: 1; display: grid; place-items: center; transition: background 0.2s, color 0.2s, border-color 0.2s; }
      .rev-btn:hover { background: var(--bronze); color: var(--white); border-color: var(--bronze); }
      @media (max-width: 768px) { .reviews__nav { display: none; } }

      /* BLOG-VORSCHAU */
      .blog { background: #f9f6f5; padding-block: var(--pad-section); display: flex; flex-direction: column; gap: var(--gap-l); }
      .blog__head { display: flex; flex-direction: column; align-items: center; gap: var(--gap-m); text-align: center; }
      .blog__over { color: var(--grey); }
      .blog__title { color: var(--text); max-width: 32ch; }
      .blog__track { display: flex; gap: var(--gap-l); overflow-x: auto; scroll-snap-type: x mandatory; padding-inline: var(--layout-margin); padding-bottom: 12px; align-items: start; }
      .bcard { flex: none; scroll-snap-align: center; color: var(--text); }
      .bcard--sq { width: clamp(220px, 22vw, 360px); }
      .bcard--sq img { width: 100%; aspect-ratio: 1 / 1; object-fit: cover; }
      .bcard--feature { width: clamp(300px, 44vw, 744px); display: flex; flex-direction: column; gap: var(--gap-s); }
      .bcard__media { height: clamp(240px, 28vw, 420px); overflow: hidden; }
      .bcard__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
      .bcard--feature:hover .bcard__media img { transform: scale(1.03); }
      .bcard__header { display: flex; justify-content: space-between; gap: 16px; }
      .bcard__header .t-titel, .bcard__header .t-small { color: var(--grey); }
      .bcard__title { color: var(--text); }

      /* Responsive */
      @media (max-width: 768px) {
