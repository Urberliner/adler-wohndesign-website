---
import "../styles/global.css";
// Adler Wohndesign — Hero (Platzhalter-Startseite, wird später aus V4 neu gebaut)
const nav = [
  { label: "Services", href: "#services" },
  { label: "Projekte", href: "#projekte" },
  { label: "Farrow & Ball", href: "#farrow-ball" },
  { label: "Das sind wir", href: "#ueber-uns" },
  { label: "Blog", href: "#blog" },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Raumausstatter Berlin | ADLER Wohndesign Charlottenburg</title>
    <meta
      name="description"
      content="ADLER Wohndesign — Meisterbetrieb seit 1939. Ganzheitliche Raumkonzepte aus Berlin-Charlottenburg: von der ersten Idee bis zum letzten Handgriff."
    />
    <!-- Schriften werden selbst gehostet (via global.css / @fontsource) -->
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <!-- Header -->
    <header class="site-header">
      <a class="logo" href="/" aria-label="ADLER Wohndesign — Startseite">
        <img src="/images/logo-white.png" alt="ADLER Wohndesign" width="2634" height="949" />
      </a>

      <nav class="main-nav" aria-label="Hauptnavigation">
        <ul>
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="header-actions">
        <button class="icon-btn" type="button" aria-label="Suche">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="16.5" y1="16.5" x2="21" y2="21"></line>
          </svg>
        </button>
        <a class="btn-cta" href="#kontakt">Mein Beratungstermin</a>
      </div>
    </header>

    <!-- Hero -->
    <main>
      <section class="hero" aria-labelledby="hero-title">
        <img
          class="hero__img"
          src="/images/hero-beratung.jpg"
          alt="ADLER Wohndesign Showroom mit Beratungssituation"
          fetchpriority="high"
        />
        <div class="hero__overlay" aria-hidden="true"></div>
        <div class="hero__content">
          <p class="overline">Raumausstatter &amp; Innenarchitektur-Studio in Berlin</p>
          <h1 id="hero-title">
            Räume, die sich anfühlen wie nach Hause kommen — nur schöner.
          </h1>
          <p class="hero__sub">
            Meisterbetrieb seit 1939. Ganzheitliche Raumkonzepte aus Charlottenburg
            — von der ersten Idee bis zum letzten Handgriff.
          </p>
        </div>
      </section>
    </main>

    <style>
      /* ---- Design Tokens (aus Figma) ---- */
      :root {
        --moos: #153032;
        --bronze: #bf8970;
        --nature: #f6f3f2;
        --grey-dark: #1f1f27;
        --grey: #8e8f93;
        --light-grey: #d4d5d9;
        --white: #ffffff;

        --font-display: "Playfair Display", Georgia, serif;
        --font-body: "Montserrat", system-ui, -apple-system, sans-serif;

        /* Spacing (mobile-first) */
        --page-margin: 24px;
        --header-h: 64px;

        /* Type scale (mobile) */
        --fs-h1: 36px;   --lh-h1: 50px;
        --fs-over: 12px; --lh-over: 20px; --ls-over: 0.12em;
        --fs-body: 16px; --lh-body: 26px;
      }

      @media (min-width: 768px) {
        :root {
          --page-margin: 32px;
          --header-h: 72px;
          --fs-h1: 44px;   --lh-h1: 58px;
          --fs-body: 16px; --lh-body: 26px;
        }
      }

      @media (min-width: 1024px) {
        :root {
          --page-margin: 80px;
          --header-h: 88px;
          --fs-h1: 64px;   --lh-h1: 88px;
          --fs-over: 14px; --lh-over: 24px;
          --fs-body: 18px; --lh-body: 32px;
        }
      }

      /* ---- Reset ---- */
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { -webkit-font-smoothing: antialiased; }
      body { font-family: var(--font-body); color: var(--grey-dark); }
      img { display: block; max-width: 100%; }
      ul { list-style: none; }
      a { text-decoration: none; color: inherit; }

      /* ---- Header ---- */
      .site-header {
        position: fixed;
        inset: 0 0 auto 0;
        height: var(--header-h);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding-inline: var(--page-margin);
        background: var(--moos);
        z-index: 10;
      }
      .logo img { height: 28px; width: auto; }
      @media (min-width: 1024px) { .logo img { height: 40px; } }

      .main-nav ul { display: flex; gap: 32px; }
      .main-nav a {
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--white);
        opacity: 0.92;
        transition: opacity 0.2s, color 0.2s;
      }
      .main-nav a:hover { color: var(--bronze); opacity: 1; }
      /* Nav versteckt auf kleinen Screens (Burger-Menü käme im echten Bau dazu) */
      @media (max-width: 1023px) { .main-nav { display: none; } }

      .header-actions { display: flex; align-items: center; gap: 16px; }
      .icon-btn {
        display: grid; place-items: center;
        width: 40px; height: 40px;
        background: none; border: none; cursor: pointer;
        color: var(--white);
      }
      @media (max-width: 1023px) { .icon-btn { display: none; } }

      .btn-cta {
        display: inline-flex; align-items: center;
        height: 44px;
        padding-inline: 24px;
        border-radius: 999px;
        background: var(--bronze);
        color: var(--white);
        font-size: 14px;
        font-weight: 500;
        letter-spacing: 0.02em;
        white-space: nowrap;
        transition: filter 0.2s;
      }
      .btn-cta:hover { filter: brightness(1.07); }

      /* ---- Hero ---- */
      .hero {
        position: relative;
        min-height: 100svh;
        display: flex;
        align-items: flex-end;
        overflow: hidden;
      }
      .hero__img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 35%;
      }
      .hero__overlay {
        position: absolute;
        inset: 0;
        /* Stärkerer Verlauf unten, damit Text über hellem Bildbereich
           lesbar bleibt (WCAG-Kontrast). */
        background: linear-gradient(
          180deg,
          rgba(31, 31, 39, 0.32) 0%,
          rgba(31, 31, 39, 0.08) 22%,
          rgba(31, 31, 39, 0.38) 50%,
          rgba(31, 31, 39, 0.82) 100%
        );
      }
      .hero__content {
        position: relative;
        z-index: 1;
        max-width: 1000px;
        padding: var(--page-margin);
        padding-bottom: clamp(40px, 8vh, 96px);
        color: var(--white);
      }
      .overline {
        font-size: var(--fs-over);
        line-height: var(--lh-over);
        letter-spacing: var(--ls-over);
        text-transform: uppercase;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.82);
        margin-bottom: 20px;
      }
      h1 {
        font-family: var(--font-display);
        font-weight: 500;
        font-size: var(--fs-h1);
        line-height: var(--lh-h1);
        letter-spacing: -0.01em;
        max-width: 16ch;
      }
      .hero__sub {
        margin-top: 24px;
        font-size: var(--fs-body);
        line-height: var(--lh-body);
        font-weight: 400;
        color: rgba(255, 255, 255, 0.88);
        max-width: 46ch;
      }
    </style>
  </body>
</html>
