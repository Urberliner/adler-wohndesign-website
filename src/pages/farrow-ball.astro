---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Farrow & Ball — Farben, Farbkonzepte & Tapeten | ADLER Wohndesign</title>
    <meta
      name="description"
      content="Farrow & Ball bei ADLER Wohndesign: Entdecken Sie die Farrow & Ball Farbwelt – Farben, harmonische Farbkonzepte, Finishes und Tapeten. Persönliche Farbberatung aus Berlin-Charlottenburg."
    />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <Header />

    <main>
      <!-- HERO image-text — Frame 12384:34762: full-bleed Bild + 50% Overlay, Text unten links -->
      <section class="fbhero">
        <div class="fbhero__media" aria-hidden="true">
          <img src="/images/hero-beratung.jpg" alt="" fetchpriority="high" />
          <span class="fbhero__overlay"></span>
        </div>
        <div class="container fbhero__inner">
          <div class="fbhero__text">
            <p class="t-titel fbhero__eyebrow">Farrow &amp; Ball</p>
            <h1 class="t-h1 fbhero__title">Wir wollen für unsere Mitarbeiter mehr sein als ein Arbeitsplatz</h1>
            <p class="t-body fbhero__lead">
              Ob ganzheitliche Wohnkonzepte oder gezielte Einzelleistungen – wir bieten Ihnen
              passgenaue Lösungen für Ihre Räume. Von der Beratung über die Planung bis zur Umsetzung
              stehen wir Ihnen mit Fachwissen und handwerklicher Präzision zur Seite. Sie entscheiden
              den Umfang, wir kümmern uns um die perfekte Ausführung.
            </p>
            <Button href="/kontakt" class="fbhero__btn">Mein Projekt starten</Button>
          </div>
        </div>
      </section>

      <!-- PROJEKT AUFBAU — Frame 12384:34771: Text links + Accordion rechts -->
      <section class="aufbau container">
        <div class="aufbau__text">
          <p class="t-titel aufbau__over"><span class="dot" aria-hidden="true"></span>Ganzheitliche Farbkonzepte</p>
          <p class="t-h4 aufbau__lead">
            Wir gestalten Ihre Räume individuell, harmonisch und funktional – ob einzelne Zimmer,
            ganze Wohnungen oder komplette Häuser. Von der ersten Idee bis zur letzten Handbewegung
            begleiten wir Sie mit Kreativität, Erfahrung und handwerklicher Präzision.
          </p>
          <!-- Button-Annotation: „Verbindung Komplettlösung" -->
          <Button href="/komplettloesung" variant="ghost" class="aufbau__btn">So sieht ihr Rundum-Service aus</Button>
        </div>
        <div class="aufbau__cards">
          <Accordion items={aufbauSchritte} name="fb-aufbau" openFirst={true} dividers={true} />
        </div>
      </section>

      <!-- SERVICES / F&B-FARBWELT — Frame 12384:34781 -->
      <section class="services container" aria-labelledby="fb-services-title">
        <div class="services__intro">
          <p class="t-titel">Teilleistungen</p>
          <h2 class="t-h2" id="fb-services-title">Individuelle Einzelleistungen</h2>
          <p class="t-body">
            Nicht immer ist eine Komplettlösung erforderlich. Sie benötigen eine Farbberatung, neue
            Vorhänge oder einen effektiven Sicht- und Sonnenschutz? Wir bieten Ihnen gezielte
            Einzelleistungen, die sich exakt an Ihren Wünschen orientieren. Ob kleines Detail oder
            gezielte Anpassung – Sie entscheiden, wir setzen es fachgerecht um.
          </p>
        </div>

        <!-- Filter-Annotation: keine echte Filterung, sondern Sprung-Navigation zu den Kategorien -->
        <nav class="services__jump" aria-label="Zu den Kategorien springen">
          {kategorien.map((k) => (
            <a class="t-titel services__jumplink" href={`#${k.id}`}>{k.title}</a>
          ))}
        </nav>

        <div class="services__kategorien">
          {kategorien.map((k) => {
            const bodyParts = Array.isArray(k.body) ? k.body : [k.body];
            return (
              <section class="kategorie" id={k.id} aria-labelledby={`${k.id}-title`}>
                <div class="kategorie__text">
                  <h3 class="t-h2 kategorie__title" id={`${k.id}-title`}>{k.title}</h3>
                  {bodyParts.map((p) => <p class="t-body">{p}</p>)}
                </div>

                {/* Desktop: 4-Spalten-Grid · Tablet/Mobil: Carousel (per 2 / 1) */}
                <Carousel tone="dark" perMobile={1} perTablet={2} perDesktop={4} label={`${k.title} — Karten`} class="kategorie__cards">
                  <li class="fbcard fbcard--feature">
                    <a class="fbcard__feature" href={k.feature.href}>
                      <span class="fbcard__feature-text">
                        <span class="t-h4 fbcard__feature-title">{k.feature.title}</span>
                        <span class="t-body fbcard__feature-body">{k.feature.text}</span>
                      </span>
                      <span class="fbcard__arrow" aria-hidden="true">
                        <Icon name="arrow_upward" size={32} />
                      </span>
                    </a>
                  </li>
                  {k.cards.map((c) => (
                    <li class="fbcard">
                      <a class="fbcard__link" href="#">
                        <span class="fbcard__media"><img src={c.img} alt={c.name} loading="lazy" /></span>
                        <span class="fbcard__body">
                          <span class="t-h5 fbcard__name">{c.name}</span>
                          <span class="t-small fbcard__nr">{c.nr}</span>
                        </span>
                      </a>
                      <FavoriteButton class="fbcard__fav" label={`${c.name} zu meinem Farbkonzept`} />
                    </li>
                  ))}
                </Carousel>
              </section>
            );
          })}
        </div>
      </section>

      <!-- ZITAT — Frame 12384:34824 -->
      <Quote author="Friedbert Bleile,<br />Kunde" bg="nature">„Diese Firma kann ich bestens empfehlen. Klasse Team mit bester fachlicher Kompetenz. Gehen ganzheitlich auf die Wünsche von Kunden ein und finden immer eine passende Lösung."</Quote>

      <!-- BLOG CATEGORIE PREVIEW — Frame 12384:34828 (bg #f9f6f5) -->
      <section class="blogprev">
        <div class="container blogprev__head">
          <p class="t-titel blogprev__over">Blog</p>
          <p class="t-h3 blogprev__title">
            Wissen, Erfahrung und Inspiration – entdecken Sie Tipps und Neuigkeiten aus unserer Welt
            der Raumgestaltung.
          </p>
        </div>
        <div class="blogprev__cards container">
          {blogTeaser.map((b) =>
            b.type === "feature" ? (
              <article class="blogcard blogcard--feature">
                <a class="blogcard__media" href={b.href}><img src={b.img} alt={b.alt} loading="lazy" /></a>
                <div class="blogcard__body">
                  <div class="blogcard__head">
                    <span class="t-titel blogcard__cat">{b.category}</span>
                    <span class="t-small blogcard__meta">{b.meta}</span>
                  </div>
                  <p class="t-h5 blogcard__title">{b.title}</p>
                  <a class="blogcard__link" href={b.href}>
                    <span class="t-small">Weiterlesen</span>
                    <Icon name="arrow_upward" size={32} class="blogcard__arrow" />
                  </a>
                </div>
              </article>
            ) : (
              <article class="blogcard blogcard--teaser" aria-hidden="true">
                <span class="blogcard__media"><img src={b.img} alt="" loading="lazy" /></span>
              </article>
            )
          )}
        </div>
      </section>

      <!-- KONTAKT — Frame 12384:34846 (weiß) -->
      <Cta
        bg="default"
        over="Kontakt"
        heading="Sie haben eine Vision für Ihr individuelles Farbkonzept?"
        lead="Vereinbaren Sie jetzt Ihre persönliche Beratung."
        buttonLabel="Mein Farbprojekt starten"
        buttonHref="/kontakt"
      />
    </main>

    <Footer />

    <style>
      /* ============ HERO image-text ============ */
      /* Frame 12384:34762: h 948, items-end, py XL/L, px margin, Text weiß über Bild + 50% Overlay. */
      .fbhero {
        position: relative;
        display: flex;
        align-items: flex-end;
        min-height: clamp(560px, 90vh, 948px);
        padding-block: var(--gap-xl) var(--gap-l);
        color: var(--white);
        overflow: hidden;
        isolation: isolate;
      }
      .fbhero__media { position: absolute; inset: 0; z-index: -1; }
      .fbhero__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
      /* gradient/overlay-50% = rgba(31,31,39,0.5) */
      .fbhero__overlay { position: absolute; inset: 0; background: rgba(31, 31, 39, 0.5); }
      .fbhero__inner { width: 100%; }
      .fbhero__text {
        display: flex;
        flex-direction: column;
        gap: var(--gap-m); /* Container Text gap = spacing/m */
        max-width: var(--text-max);
      }
      .fbhero__eyebrow { color: var(--white); }
      .fbhero__title { color: var(--white); }
      .fbhero__lead { color: var(--white); max-width: 70ch; }
      .fbhero__btn { align-self: flex-start; margin-top: var(--gap-xs); }

      /* ============ PROJEKT AUFBAU ============ */
      /* Frame 12384:34771: py XXL/XL; 2-spaltig (Text | Cards). */
      .aufbau {
        display: flex;
        flex-direction: column;
        gap: var(--gap-ml);
        padding-block: var(--gap-xxl) var(--gap-xl);
      }
      .aufbau__text {
        display: flex;
        flex-direction: column;
        gap: var(--gap-s); /* Frame: gap spacing/s */
        max-width: var(--text-max);
      }
      .aufbau__over { display: flex; align-items: center; gap: var(--gap-xs); color: var(--grey); }
      .dot { width: 12px; height: 12px; border-radius: 50%; background: var(--bronze); flex: none; }
      .aufbau__lead { color: var(--text); }
      .aufbau__btn { align-self: flex-start; }

      /* ============ SERVICES / F&B-FARBWELT ============ */
      /* Frame 12384:34781: py XXL/XL, gap XL zwischen Intro / Kategorien. */
      .services {
        display: flex;
        flex-direction: column;
        gap: var(--gap-xl);
        padding-block: var(--gap-xxl) var(--gap-xl);
      }
      .services__intro {
        display: flex;
        flex-direction: column;
        gap: var(--gap-xs);
        max-width: var(--text-max);
      }
      .services__intro .t-h2 { color: var(--text); }

      /* Sprung-Navigation (statt echtem Filter) */
      .services__jump {
        display: flex;
        flex-wrap: wrap;
        gap: var(--gap-s);
      }
      .services__jumplink {
        color: var(--grey);
        text-decoration: underline transparent;
        text-underline-offset: 4px;
        transition: color 0.2s ease, text-decoration-color 0.2s ease;
      }
      .services__jumplink:hover { color: var(--bronze); text-decoration-color: currentColor; }

      /* Kategorie-Container: gap XL zwischen Kategorien (Frame 12384:34783). */
      .services__kategorien {
        display: flex;
        flex-direction: column;
        gap: var(--gap-xl);
      }
      /* Einzelne Kategorie: gap L zwischen Text und Karten (Frame 12384:34785). */
      .kategorie {
        display: flex;
        flex-direction: column;
        gap: var(--gap-l);
        scroll-margin-top: 96px; /* Anker unter fixierter Nav */
      }
      .kategorie__text {
        display: flex;
        flex-direction: column;
        gap: var(--gap-xs);
        max-width: var(--text-max);
      }
      .kategorie__title { color: var(--text); }

      /* --- F&B-Karten --- */
      .fbcard { list-style: none; position: relative; display: flex; }
      .fbcard__link {
        display: flex;
        flex-direction: column;
        gap: var(--gap-xs);
        color: var(--text);
        width: 100%;
      }
      .fbcard__media { display: block; aspect-ratio: 1 / 1; overflow: hidden; }
      .fbcard__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
      .fbcard__link:hover .fbcard__media img { transform: scale(1.03); }
      .fbcard__body { display: flex; flex-direction: column; gap: var(--gap-xxxs); }
      .fbcard__name { color: var(--text); }
      .fbcard__nr { color: var(--grey); }
      /* FavoriteButton oben rechts auf der Karte (Figma: Button-function, Kreis + Herz). */
      .fbcard__fav { position: absolute; top: 12px; right: 12px; z-index: 1; }

      /* Feature-Karte (moos): Titel + Body oben, Pfeil-Button unten rechts. */
      .fbcard--feature { height: auto; }
      .fbcard__feature {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: var(--gap-sm);
        width: 100%;
        background: var(--moos);
        color: var(--white);
        /* Frame 12384:34789: pt M, pb S, px S */
        padding: var(--gap-m) var(--gap-s) var(--gap-s);
        aspect-ratio: 1 / 1;
      }
      .fbcard__feature-text { display: flex; flex-direction: column; gap: var(--gap-xxs); }
      .fbcard__feature-title { color: var(--white); }
      .fbcard__feature-body { color: var(--white); }
      .fbcard__arrow {
        align-self: flex-end;
        display: grid;
        place-items: center;
        width: 36px;
        height: 36px;
        color: var(--white);
        transition: color 0.2s ease, transform 0.2s ease;
      }
      /* arrow_upward (Aufwärtspfeil) → 90° = nach rechts (wie Figma). */
      .fbcard__arrow :global(svg) { transform: rotate(90deg); }
      .fbcard__feature:hover .fbcard__arrow { color: var(--bronze); transform: translateX(4px); }

      /* ============ BLOG CATEGORIE PREVIEW ============ */
      /* Frame 12384:34828: bg #f9f6f5, py XXL, gap L zwischen Kopf und Karten, zentriert. */
      .blogprev {
        background: #f9f6f5;
        padding-block: var(--gap-xxl);
        display: flex;
        flex-direction: column;
        gap: var(--gap-l);
      }
      .blogprev__head {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--gap-m);
        text-align: center;
      }
      .blogprev__title { color: var(--text); max-width: var(--text-max); }

      /* Karten-Reihe: zentriert, horizontal scrollbar (Feature groß zwischen Teasern). */
      .blogprev__cards {
        display: flex;
        gap: var(--gap-l);
        align-items: flex-start;
        justify-content: flex-start;
        overflow-x: auto;
        scrollbar-width: none;
        scroll-snap-type: x mandatory;
      }
      .blogprev__cards::-webkit-scrollbar { display: none; }
      .blogcard { scroll-snap-align: center; flex: none; }
      .blogcard__media { display: block; overflow: hidden; }
      .blogcard__media img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.6s ease; }
      .blogcard__media:hover img { transform: scale(1.03); }

      .blogcard--teaser { width: 360px; }
      .blogcard--teaser .blogcard__media { aspect-ratio: 1 / 1; }

      .blogcard--feature { width: 744px; max-width: 100%; display: flex; flex-direction: column; gap: var(--gap-s); }
      .blogcard--feature .blogcard__media { height: 420px; }
      .blogcard__body { display: flex; flex-direction: column; gap: var(--gap-xs); }
      .blogcard__head { display: flex; justify-content: space-between; gap: 16px; color: var(--grey); }
      .blogcard__title { color: var(--text); }
      .blogcard__link {
        display: inline-flex;
        align-items: center;
        gap: var(--gutter);
        color: var(--text);
        transition: color 0.2s ease;
      }
      .blogcard__link:hover { color: var(--bronze); }
      .blogcard__link :global(.blogcard__arrow) :global(svg) { transform: rotate(90deg); }

      /* ============ Breakpoints (kanonisch 701 / 992) ============ */
      @media (min-width: 701px) {
        .aufbau { display: grid; grid-template-columns: 1fr 1fr; gap: var(--gutter); align-items: start; }
        .aufbau__text { max-width: none; }
      }

      @media (min-width: 992px) {
        /* Desktop: F&B-Karten als 4-Spalten-Grid (kein Carousel-Scroll). Punkte blendet
           Carousel.astro aus, sobald alles passt. */
        .kategorie__cards :global(.carousel__track) {
          display: grid;
          grid-template-columns: repeat(4, 1fr);
          gap: var(--gutter);
          overflow: visible;
        }
        .kategorie__cards :global(.carousel__track) > .fbcard { width: auto; }
      }
    </style>
  </body>
</html>
