      { name: "Wimborne Group", nr: "Neutralgruppe 2", img: farbBild },
      { name: "Cromarty Group", nr: "Neutralgruppe 3", img: farbBild },
      { name: "Off-Black Group", nr: "Neutralgruppe 4", img: farbBild },
      { name: "Drop Cloth Group", nr: "Neutralgruppe 5", img: farbBild },
