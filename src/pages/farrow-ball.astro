// --- Blog Categorie Preview: Karten (12384:34831–34843) ---
// Feature-Card (groß) + quadratische Bild-Teaser. Bilder = Platzhalter.
const blogTeaser = [
  { type: "image", img: "/images/home/blog-akustik.jpg", alt: "Blogartikel" },
  { type: "image", img: "/images/komplettloesung/card2.png", alt: "Blogartikel" },
  {
    type: "feature",
    img: "/images/home/team.jpg",
    alt: "Aktueller Artikel: Gesellenprüfung zur Raumausstatterin Kimberly Fischer",
