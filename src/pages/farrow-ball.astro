      { name: "Marmelo", nr: "Nr. 316", img: farbBild },
      { name: "Tunsgate Green", nr: "Nr. 250", img: farbBild },
      { name: "Stone Blue", nr: "Nr. 86", img: farbBild },
      { name: "Pale Hound", nr: "Nr. 71", img: farbBild },
      { name: "Setting Plaster", nr: "Nr. 231", img: farbBild },
    ],
