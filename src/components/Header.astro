---
const nav = [
  { label: "Services", href: "/services" },
  { label: "Projekte", href: "/projekte" },
  { label: "Farrow & Ball", href: "/farrow-ball" },
  { label: "Das sind wir", href: "/ueber-uns" },
  { label: "Blog", href: "/blog" },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="logo" href="/" aria-label="ADLER Wohndesign — Startseite">
      <img src="/images/logo-white.png" alt="ADLER Wohndesign" width="2634" height="949" />
    </a>

    <nav class="main-nav" aria-label="Hauptnavigation">
      <ul>
        {nav.map((item) => (
          <li><a class="t-titel" href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <button class="icon-btn" type="button" aria-label="Suche">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="16.5" y1="16.5" x2="21" y2="21"></line>
        </svg>
      </button>
      <a class="btn" href="/kontakt">Mein Termin</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    background: var(--moos);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-header__inner {
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .logo img { height: 40px; width: auto; }

  .main-nav ul { display: flex; align-items: center; gap: 8px; }
  .main-nav a {
    color: var(--white);
    padding: 8px;
    transition: color 0.2s ease;
  }
  .main-nav a:hover { color: var(--bronze); }

  .header-actions { display: flex; align-items: center; gap: 6px; }
  .icon-btn {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    color: var(--white);
  }

  /* Unter 1024px: Nav + Suche aus (Burger-Menü = To-do im echten Bau) */
  @media (max-width: 1023px) {
    .site-header__inner { height: 72px; }
    .main-nav, .icon-btn { display: none; }
    .logo img { height: 32px; }
  }
</style>
