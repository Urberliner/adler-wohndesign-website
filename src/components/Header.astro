---
// Hauptnavigation (V4) — 1:1 aus Figma (Frames 5152:4275 Bar, 5163:9757 Dropdown, 5658:12572 OnClick)
// Desktop: Bar + Mega-Dropdown (Liste links, Bild rechts). Tablet/Mobil: Bar (Lupe+Telefon+Burger) + Vollbild-Overlay.
// Motion: Bar versteckt beim Runterscrollen, erscheint beim Hochscrollen (weich).
import Icon from "./Icon.astro";

const tel = "+49 30 305 47 11";
const telHref = "tel:+49303054711";

const nav = [
  {
    id: "services",
    label: "Services",
    href: "/services",
    image: "/images/home/project-1.jpg",
    panel: [
      { label: "Komplettlösung", href: "/komplettloesung" },
      { label: "Einzelleistungen", heading: true },
      { label: "Gardinen & Rollos", href: "/services/gardinen-rollos", children: [
        { label: "Vorhänge", href: "/services/vorhaenge" },
        { label: "Raffrollos", href: "/services/gardinen-rollos#raffrollos" },
        { label: "Flächenvorhänge", href: "/services/gardinen-rollos#flaechenvorhaenge" },
        { label: "Gardinenstangen", href: "/services/gardinen-rollos#gardinenstangen" },
        { label: "Rollos", href: "/services/gardinen-rollos#rollos" },
        { label: "Lamellenvorhänge", href: "/services/gardinen-rollos#lamellenvorhaenge" },
      ] },
      { label: "Stoffe", href: "/services/stoffe" },
      { label: "Einrichtung", href: "/services/einrichtung" },
      { label: "Boden", href: "/services/boden" },
      { label: "Wand", href: "/services/wand" },
    ],
  },
  { id: "projekte", label: "Projekte", href: "/projekte" },
  {
    id: "farrow-ball",
    label: "Farrow & Ball",
    href: "/farrow-ball",
    image: "/images/home/project-2.jpg",
    panel: [
      { label: "Komplettlösung", href: "/farrow-ball" },
      { label: "Farben", href: "/farrow-ball/farben" },
      { label: "Farbkonzepte", href: "/farrow-ball/farbkonzepte" },
      { label: "Tapeten", href: "/farrow-ball/tapeten" },
    ],
  },
  {
    id: "dassindwir",
    label: "Das sind wir",
    href: "/ueber-uns",
    image: "/images/home/team.jpg",
    panel: [
      { label: "Unser Team", href: "/team" },
      { label: "Karriere", href: "/karriere" },
      { label: "Historie", href: "/historie" },
      { label: "Partner", href: "/partner" },
    ],
  },
  { id: "blog", label: "Blog", href: "/blog" },
];
---

<header class="site-header" id="siteHeader">
  <div class="nav-bar">
    <div class="nav-inner">
      <a class="logo" href="/" aria-label="ADLER Wohndesign — Startseite">
        <img src="/images/logo-white.png" alt="ADLER Wohndesign" width="2634" height="949" />
      </a>

      <nav class="desk-nav" aria-label="Hauptnavigation">
        <ul>
          {nav.map((item) => (
            <li>
              {item.panel ? (
                <button type="button" class="t-titel nav-trigger" data-mega={item.id} aria-expanded="false" aria-controls={`mega-${item.id}`}>
                  {item.label}<Icon name="chevron-down" size={16} class="nav-chev" />
                </button>
              ) : (
                <a class="t-titel nav-link" href={item.href}>{item.label}</a>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <div class="nav-actions">
        <button class="icon-btn" type="button" aria-label="Suche"><Icon name="search" size={24} /></button>
        <a class="icon-btn nav-phone" href={telHref} aria-label={`Anrufen: ${tel}`}><Icon name="phone" size={24} /></a>
        <a class="btn nav-cta" href="/kontakt">Mein Termin</a>
        <button class="icon-btn burger" type="button" aria-label="Menü öffnen" aria-expanded="false" aria-controls="mobileNav"><Icon name="burger" size={24} /></button>
      </div>
    </div>
  </div>

  <!-- Desktop Mega-Menü-Panels -->
  {nav.filter((i) => i.panel).map((item) => (
    <div class="mega" id={`mega-${item.id}`} hidden>
      <div class="nav-inner mega__inner">
        <ul class="mega__list">
          {item.panel.map((entry) => (
            entry.heading ? (
              <li class="mega__heading t-small">{entry.label}</li>
            ) : (
              <li>
                <a class="mega__item" href={entry.href}>{entry.label}</a>
                {entry.children && (
                  <ul class="mega__sub">
                    {entry.children.map((c) => (<li><a href={c.href}>{c.label}</a></li>))}
                  </ul>
                )}
              </li>
            )
          ))}
        </ul>
        <div class="mega__media"><img src={item.image} alt="" loading="lazy" /></div>
      </div>
    </div>
  ))}
</header>

<!-- Mobiles Vollbild-Menü -->
<div class="mobile-nav" id="mobileNav" hidden>
  <div class="mobile-nav__bar">
    <span class="logo"><img src="/images/logo-white.png" alt="ADLER Wohndesign" width="2634" height="949" /></span>
    <button class="icon-btn mobile-close" type="button" aria-label="Menü schließen"><Icon name="close" size={26} /></button>
  </div>
  <nav class="mobile-nav__body" aria-label="Hauptnavigation mobil">
    {nav.map((item) => (
      item.panel ? (
        <details class="m-sec">
          <summary><span class="t-h4">{item.label}</span><Icon name="chevron-down" size={24} class="m-chev" /></summary>
          <div class="m-sec__body">
            {item.panel.map((entry) => (
              entry.heading ? (
                <p class="m-heading t-small">{entry.label}</p>
              ) : entry.children ? (
                <details class="m-sub">
                  <summary><a href={entry.href} class="t-body">{entry.label}</a><Icon name="chevron-down" size={22} class="m-chev" /></summary>
                  <div class="m-sub__body">
                    {entry.children.map((c) => (<a href={c.href} class="t-body">{c.label}</a>))}
                  </div>
                </details>
              ) : (
                <a href={entry.href} class="t-body m-link">{entry.label}</a>
              )
            ))}
          </div>
        </details>
      ) : (
        <a href={item.href} class="t-h4 m-toplink">{item.label}</a>
      )
    ))}
    <a href="/kontakt" class="t-h4 m-toplink">Kontakt</a>
    <a class="btn mobile-cta" href="/kontakt">Mein Termin</a>
  </nav>
</div>

<style>
  .site-header { background: var(--moos); position: sticky; top: 0; z-index: 50; transition: transform 0.3s ease; }
  .site-header.is-hidden { transform: translateY(-100%); }
  /* hidden-Attribut muss display-Regeln überschreiben (sonst bleibt das Overlay sichtbar) */
  [hidden] { display: none !important; }

  /* Bar: volle Breite, eigenes Seiten-Padding (Figma margin/horizontal); innen zentrierter Container max 1600 */
  .nav-bar { padding-inline: 24px; }
  .nav-inner { width: 100%; max-width: 1600px; margin-inline: auto; }
  .nav-bar .nav-inner { height: 96px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
  .logo img { height: 44px; width: auto; }

  /* Desktop-Nav: 5 Tabs gleichmäßig in 560–640px-Gruppe */
  .desk-nav { flex: 1 1 auto; display: flex; justify-content: center; }
  .desk-nav ul { display: flex; align-items: center; justify-content: space-between; gap: 8px; width: 100%; max-width: 640px; min-width: 560px; }
  .nav-trigger, .nav-link { display: inline-flex; align-items: center; gap: 4px; color: var(--white); padding: 8px; position: relative; transition: color 0.2s ease; }
  /* Hover/aktiv: bronze + Unterstrich (Figma Navigation Tab) */
  .nav-trigger::after, .nav-link::after { content: ""; position: absolute; left: 8px; right: 8px; bottom: 4px; height: 1px; background: var(--bronze); transform: scaleX(0); transition: transform 0.2s ease; }
  .nav-trigger:hover, .nav-link:hover, .nav-trigger[aria-expanded="true"] { color: var(--bronze); }
  .nav-trigger:hover::after, .nav-link:hover::after, .nav-trigger[aria-expanded="true"]::after { transform: scaleX(1); }
  .nav-chev :global(svg) { transition: transform 0.25s ease; }
  .nav-trigger[aria-expanded="true"] .nav-chev :global(svg) { transform: rotate(180deg); }

  .nav-actions { display: flex; align-items: center; gap: var(--gap-xs); }
  .icon-btn { display: grid; place-items: center; width: 40px; height: 40px; color: var(--white); transition: color 0.2s ease; }
  .icon-btn:hover { color: var(--bronze); }
  .nav-phone, .burger { display: none; } /* nur Tablet/Mobil */

  /* Mega-Menü (Desktop) — exakt aus Figma (5659:13071): Liste links + Bild rechts.
     Dropdown px=layout-margin, pt=spacing/m 56, pb=spacing/l 104, gap=gutter 32. */
  .mega { position: absolute; left: 0; right: 0; top: 100%; background: var(--moos); box-shadow: 0 24px 40px rgba(0,0,0,0.25); }
  .mega__inner { display: flex; gap: var(--gutter); align-items: center; padding-block: var(--gap-m) var(--gap-l); padding-inline: var(--layout-margin); }
  .mega__list { flex: 1 1 0; display: flex; flex-direction: column; gap: var(--gap-s); }
  .mega__list > li { padding-left: var(--gap-sm); } /* spacing/sm 44 */
  .mega__heading { color: var(--grey); text-transform: none; padding-left: 0 !important; font-size: 15px; letter-spacing: 0.03em; }
  .mega__item { color: var(--white); font-size: 15px; letter-spacing: 0.03em; transition: color 0.2s ease; }
  .mega__item:hover { color: var(--bronze); }
  .mega__sub { display: flex; flex-direction: column; padding-left: var(--gap-m); } /* spacing/m 56 */
  .mega__sub a { color: var(--white); font-size: 15px; line-height: 27px; letter-spacing: 0.03em; transition: color 0.2s ease; }
  .mega__sub a:hover { color: var(--bronze); }
  .mega__media { flex: 1 1 0; min-width: 0; aspect-ratio: 600 / 400; overflow: hidden; }
  .mega__media img { width: 100%; height: 100%; object-fit: cover; }

  /* Burger-Icon-Strichstärke (echtes Figma-Icon) */

  /* Mobiles Overlay */
  .mobile-nav { position: fixed; inset: 0; background: var(--moos); color: var(--white); z-index: 60; overflow-y: auto; display: flex; flex-direction: column; padding-inline: 24px; }
  .mobile-nav__bar { height: 96px; display: flex; align-items: center; justify-content: space-between; }
  .mobile-nav__bar .logo img { height: 44px; }
  .mobile-close { color: var(--white); }
  .mobile-nav__body { display: flex; flex-direction: column; gap: var(--gap-s); padding-bottom: var(--gap-l); }
  .m-toplink, .m-sec > summary { color: var(--white); }
  .m-sec { border: 0; }
  .m-sec > summary, .m-sub > summary { list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding-block: 6px; }
  .m-sec > summary::-webkit-details-marker, .m-sub > summary::-webkit-details-marker { display: none; }
  .m-chev :global(svg) { color: var(--bronze); transition: transform 0.25s ease; flex: none; }
  details[open] > summary .m-chev :global(svg) { transform: rotate(180deg); }
  .m-sec__body { display: flex; flex-direction: column; gap: 14px; padding: 10px 0 18px 16px; }
  .m-sec__body a, .m-sub__body a { color: rgba(255,255,255,0.85); }
  .m-heading { color: var(--grey); }
  .m-sub > summary { padding-block: 2px; }
  .m-sub__body { display: flex; flex-direction: column; gap: 10px; padding: 8px 0 4px 24px; }
  .mobile-cta { align-self: flex-start; margin-top: var(--gap-s); }

  /* Breakpoints (Figma-Grid): Tablet/Mobil ≤991, Desktop ≥992 */
  @media (min-width: 701px) { .nav-bar { padding-inline: 32px; } .mobile-nav { padding-inline: 32px; } }
  @media (min-width: 992px) { .nav-bar { padding-inline: 40px; } }
  @media (max-width: 991px) {
    .desk-nav, .nav-cta { display: none; }
    .nav-phone, .burger { display: grid; }
    .nav-bar .nav-inner { height: 96px; }
  }
  body.nav-open { overflow: hidden; }
</style>

<script>
  // Desktop Mega-Menü
  const header = document.getElementById("siteHeader");
  const triggers = Array.from(document.querySelectorAll("[data-mega]"));
  const closeAll = () => triggers.forEach((t) => {
    t.setAttribute("aria-expanded", "false");
    const p = document.getElementById("mega-" + (t as HTMLElement).dataset.mega);
    if (p) (p as HTMLElement).hidden = true;
  });
  triggers.forEach((t) => {
    t.addEventListener("click", (e) => {
      e.stopPropagation();
      const panel = document.getElementById("mega-" + (t as HTMLElement).dataset.mega);
      const isOpen = t.getAttribute("aria-expanded") === "true";
      closeAll();
      if (!isOpen && panel) { t.setAttribute("aria-expanded", "true"); panel.hidden = false; }
    });
  });
  document.addEventListener("click", (e) => { if (header && !header.contains(e.target as Node)) closeAll(); });

  // Mobiles Menü
  const burger = document.querySelector(".burger");
  const mobileNav = document.getElementById("mobileNav");
  const openMobile = () => { if (!mobileNav) return; mobileNav.hidden = false; document.body.classList.add("nav-open"); burger?.setAttribute("aria-expanded", "true"); };
  const closeMobile = () => { if (!mobileNav) return; mobileNav.hidden = true; document.body.classList.remove("nav-open"); burger?.setAttribute("aria-expanded", "false"); };
  burger?.addEventListener("click", openMobile);
  document.querySelector(".mobile-close")?.addEventListener("click", closeMobile);
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") { closeAll(); closeMobile(); } });

  // Scroll-Motion: Bar versteckt beim Runterscrollen, erscheint beim Hochscrollen
  let lastY = window.scrollY;
  let ticking = false;
  window.addEventListener("scroll", () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const y = window.scrollY;
      if (header) {
        if (y > lastY && y > 120) { header.classList.add("is-hidden"); closeAll(); }
        else { header.classList.remove("is-hidden"); }
      }
      lastY = y;
      ticking = false;
    });
  }, { passive: true });
</script>
