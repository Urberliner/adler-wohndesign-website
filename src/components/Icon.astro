---
// Icon — echte Designer-SVGs aus Figma V4 (Material-Symbols-Stil, Export via REST-API).
// Quelle: src/icons/<name>.svg, inline eingebunden (currentColor → einfärbbar, kein Extra-Request).
// Verwendung: <Icon name="search" size={36} />  ·  dekorativ ist Standard (aria-hidden).
// Für bedeutungstragende Icons `label` setzen → role="img" + aria-label.
//
// Figma-Größenstufen (Variablen): XS 22 · small 32 · medium 36 · large 40.
// Default 36 (Icon-medium). SVGs tragen viewBox; width/height werden entfernt, CSS steuert die Größe.
interface Props {
  name: string;
  size?: number;
  label?: string;
  class?: string;
  [key: string]: unknown;
}
const { name, size = 36, label, class: cls = "", ...rest } = Astro.props;

// Alle echten SVGs zur Build-Zeit als Rohtext einlesen.
const files = import.meta.glob<string>("../icons/*.svg", { query: "?raw", import: "default", eager: true });
const registry: Record<string, string> = {};
for (const path in files) {
  const key = path.split("/").pop()!.replace(/\.svg$/, "");
  registry[key] = files[path];
}

// Alias: im Code genutzte Namen → echte Datei (nur wo eindeutig).
const ALIAS: Record<string, string> = {
  "chevron-down": "arrow-down", // Aufklapp-Chevron = Figma keyboard_arrow_down
  "chevron-up": "arrow-up",
};
const resolved = ALIAS[name] ?? name;
let raw = registry[resolved];

if (!raw && import.meta.env.DEV) {
  console.warn(`[Icon] Unbekanntes Icon: "${name}" (aufgelöst: "${resolved}"). Verfügbar: ${Object.keys(registry).sort().join(", ")}`);
}

// width/height aus dem <svg> entfernen → Größe kommt aus CSS (--icon-size).
let svg = raw ? raw.replace(/<svg([^>]*?)\s(width|height)="[^"]*"/g, "<svg$1").replace(/<svg([^>]*?)\s(width|height)="[^"]*"/g, "<svg$1") : "";

const isLabelled = Boolean(label);
---
{svg && (
  <span
    class:list={["icon", cls]}
    style={`--icon-size:${size}px`}
    role={isLabelled ? "img" : undefined}
    aria-label={isLabelled ? label : undefined}
    aria-hidden={isLabelled ? undefined : "true"}
    set:html={svg}
    {...rest}
  />
)}

<style>
  .icon { display: inline-flex; flex: none; line-height: 0; color: inherit; }
  .icon :global(svg) { width: var(--icon-size); height: var(--icon-size); display: block; }
</style>
