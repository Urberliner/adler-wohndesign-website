---
const entdecke = ["Services", "Projekte", "Farrow & Ball", "Das sind wir", "Blog"];
const rechtliches = ["Datenschutz", "Impressum", "Cookie Einstellungen"];
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-contact">
      <a href="mailto:info@adler-wohndesign.de" class="footer-mail">info@adler-wohndesign.de</a>
      <p class="footer-phone">+49 30 305 47 11</p>
    </div>

    <div class="footer-cols">
      <div class="footer-col">
        <p class="t-titel">Entdecke</p>
        <ul class="footer-links">
          {entdecke.map((l) => (<li><a href="#">{l}</a></li>))}
        </ul>
      </div>

      <div class="footer-col">
        <p class="t-titel">Kontakt</p>
        <div class="footer-kontakt">
          <p>Mo. – Fr. 10.00 Uhr bis 19.00 Uhr<br />Samstag 10.00 Uhr bis 14.00 Uhr</p>
          <p>Reichsstraße 101<br />14052 Berlin-Charlottenburg</p>
          <p>info@adler-wohndesign.de<br />+49 30 305 47 11</p>
        </div>
      </div>

      <div class="footer-col">
        <p class="t-titel">Social Media</p>
        <div class="footer-social" aria-label="Soziale Medien">
          <a href="#" aria-label="Pinterest"><svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.64 7.86 6.36 9.32-.09-.79-.17-2 .03-2.86.18-.78 1.17-4.97 1.17-4.97s-.3-.6-.3-1.48c0-1.39.8-2.42 1.8-2.42.85 0 1.26.64 1.26 1.4 0 .85-.54 2.13-.82 3.31-.24.99.5 1.8 1.48 1.8 1.77 0 3.13-1.87 3.13-4.57 0-2.39-1.72-4.06-4.17-4.06-2.84 0-4.5 2.13-4.5 4.33 0 .86.33 1.78.74 2.28.08.1.09.19.07.29-.08.32-.25 1-.28 1.14-.04.18-.15.22-.34.13-1.25-.58-2.03-2.4-2.03-3.87 0-3.15 2.29-6.04 6.6-6.04 3.47 0 6.16 2.47 6.16 5.77 0 3.45-2.17 6.22-5.19 6.22-1.01 0-1.97-.53-2.29-1.15l-.62 2.37c-.23.86-.83 1.94-1.24 2.6.94.29 1.92.44 2.95.44 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg></a>
          <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
          <a href="#" aria-label="Facebook"><svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M14 9h3V6h-3c-1.66 0-3 1.34-3 3v2H9v3h2v7h3v-7h2.5l.5-3H14V9.5c0-.28.22-.5.5-.5z"/></svg></a>
          <a href="#" aria-label="LinkedIn"><svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5A2.5 2.5 0 1 0 5 8.5a2.5 2.5 0 0 0-.02-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-.95 1.83-1.95 3.76-1.95 4.02 0 4.76 2.5 4.76 5.76V21h-4v-5.3c0-1.27-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V21h-4z"/></svg></a>
        </div>
      </div>

      <div class="footer-col">
        <p class="t-titel">Rechtliches</p>
        <ul class="footer-links">
          {rechtliches.map((l) => (<li><a href="#">{l}</a></li>))}
        </ul>
      </div>
    </div>

    <p class="footer-credit t-small">madebyfranzi</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--moos);
    color: var(--white);
    padding-block: var(--gap-ml) var(--gap-sm);
  }
  .site-footer .container {
    display: flex;
    flex-direction: column;
    gap: var(--gap-l);
  }
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xxs);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.42;
  }
  .footer-mail { text-decoration: underline; text-underline-offset: 3px; }
  .footer-phone { letter-spacing: 0.03em; }

  .footer-cols {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-l) var(--gap-xl);
  }
  .footer-col { display: flex; flex-direction: column; gap: var(--gap-s); }
  .footer-col .t-titel { color: var(--grey); }

  .footer-links { display: flex; flex-direction: column; gap: var(--gap-xxs); }
  .footer-links a {
    font-size: 12px;
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }
  .footer-links a:hover { color: var(--bronze); }

  .footer-kontakt {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xxs);
    font-size: 12px;
    line-height: 1.83;
    letter-spacing: 0.01em;
    color: var(--white);
  }

  .footer-social { display: flex; gap: var(--gap-xxs); }
  .footer-social a {
    color: var(--white);
    transition: color 0.2s ease;
  }
  .footer-social a:hover { color: var(--bronze); }

  .footer-credit { color: var(--grey); align-self: center; }
</style>
