---
// Footer (V4) — 1:1 aus Figma (5427:10429 desktop). Werte: pt ml 78 / pb sm 44, Block-Gap l 104,
// Spalten-Gap xl 142, Spaltenbreiten 222/262/222/174, Kontakt-Info H4 24, Listen Small 12, Titel grau 11.
// Reichsstraße 100 (Inhaber-Vorgabe, überschreibt veraltetes Figma „101").
import Icon from "./Icon.astro";

const entdecke = [
  { label: "Services", href: "/services" },
  { label: "Projekte", href: "/projekte" },
  { label: "Farrow & Ball", href: "/farrow-ball" },
  { label: "Das sind wir", href: "/ueber-uns" },
  { label: "Blog", href: "/blog" },
];
const rechtliches = [
  { label: "Datenschutz", href: "/datenschutz" },
  { label: "Impressum", href: "/impressum" },
  { label: "Cookie Einstellungen", href: "#" },
];
const social = [
  { name: "pinterest", label: "Pinterest", href: "#" },
  { name: "instagram", label: "Instagram", href: "#" },
  { name: "facebook", label: "Facebook", href: "#" },
  { name: "linkedin", label: "LinkedIn", href: "#" },
];
---

<footer class="site-footer">
  <div class="footer__inner">
    <!-- Kontakt-Info groß (H4) -->
    <div class="footer-contact">
      <a href="mailto:info@adler-wohndesign.de" class="footer-mail">info@adler-wohndesign.de</a>
      <p class="footer-phone">+49 30 305 47 11</p>
    </div>

    <!-- Spalten -->
    <div class="footer-cols">
      <div class="footer-group">
        <div class="footer-col footer-col--entdecke">
          <p class="t-titel">Entdecke</p>
          <ul class="footer-links">
            {entdecke.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
          </ul>
        </div>

        <div class="footer-col footer-col--kontakt">
          <p class="t-titel">Kontakt</p>
          <div class="footer-kontakt">
            <p>Mo. – Fr. 10.00 Uhr bis 19.00 Uhr<br />Samstag 10.00 Uhr bis 14.00 Uhr</p>
            <p>Reichsstraße 100<br />14052 Berlin-Charlottenburg</p>
            <p>info@adler-wohndesign.de<br />+49 30 305 47 11</p>
          </div>
        </div>
      </div>

      <div class="footer-group">
        <div class="footer-col footer-col--social">
          <p class="t-titel">Social Media</p>
          <div class="footer-social" aria-label="Soziale Medien">
            {social.map((s) => (
              <a href={s.href} aria-label={s.label}><Icon name={s.name} size={32} /></a>
            ))}
          </div>
        </div>

        <div class="footer-col footer-col--recht">
          <p class="t-titel">Rechtliches</p>
          <ul class="footer-links">
            {rechtliches.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
          </ul>
        </div>
      </div>
    </div>

    <p class="footer-credit">madebyfranzi</p>
  </div>
</footer>

<style>
  /* Figma 5427:10429: pt ml(78) / pb sm(44), seitlich layout-margin, Block-Gap l(104) */
  .site-footer { background: var(--moos); color: var(--white); }
  .footer__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--layout-margin);
    padding-block: var(--gap-ml) var(--gap-sm);
    display: flex;
    flex-direction: column;
    gap: var(--gap-l);
  }

  /* Kontakt-Info groß: H4 24/34 Medium */
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xxs);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 24px;
    line-height: 34px;
  }
  .footer-mail { text-decoration: underline; text-underline-offset: 3px; }
  .footer-phone { letter-spacing: 0.03em; }

  /* Spalten: zwei Gruppen à zwei Spalten, Gap xl(142) */
  .footer-cols { display: flex; flex-wrap: wrap; gap: var(--gap-l) var(--gap-xl); width: 100%; }
  .footer-group { display: flex; flex-wrap: wrap; gap: var(--gap-l) var(--gap-xl); }
  .footer-col { display: flex; flex-direction: column; gap: var(--gap-s); flex: none; }
  .footer-col--entdecke { width: 222px; }
  .footer-col--kontakt { width: 262px; }
  .footer-col--social { width: 222px; }
  .footer-col--recht { width: 174px; }
  .footer-col .t-titel { color: var(--grey); }

  /* Link-Listen: Small 12/22 */
  .footer-links { display: flex; flex-direction: column; gap: var(--gap-xxs); }
  .footer-links a {
    font-size: 12px;
    line-height: 22px;
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }
  .footer-links a:hover { color: var(--bronze); }

  .footer-kontakt {
    display: flex;
    flex-direction: column;
    gap: var(--gap-xxs);
    font-size: 12px;
    line-height: 22px;
    letter-spacing: 0.01em;
    color: var(--white);
  }

  .footer-social { display: flex; gap: var(--gap-xxs); }
  .footer-social a { color: var(--white); transition: color 0.2s ease; }
  .footer-social a:hover { color: var(--bronze); }

  /* madebyfranzi — zentriert, grau, Small 12 */
  .footer-credit {
    align-self: center;
    color: var(--grey);
    font-size: 12px;
    line-height: 22px;
    letter-spacing: 0.01em;
  }
</style>
