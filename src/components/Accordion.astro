---
// Accordion — aufklappbare Liste (Figma V4: „Card Information")
// Nutzt natives <details name> (exklusiv aufklappend) — kein JS nötig.
// Innenabstand 1:1 aus Figma: px = spacing/sm, py = spacing/xs.
//
// Props:
//  - items:     [{ titel, text }]
//  - name:      gemeinsamer Gruppen-Name (default "accordion")
//  - openFirst: erstes Element offen (default true)
//  - dividers:  Trennlinien zwischen Einträgen (default true; Startseite: false)
import Icon from "./Icon.astro";
interface Item {
  titel: string;
  text: string;
}
interface Props {
  items: Item[];
  name?: string;
  openFirst?: boolean;
  dividers?: boolean;
}
const { items, name = "accordion", openFirst = true, dividers = true } = Astro.props;
---
<div class:list={["accordion", { "accordion--dividers": dividers }]}>
  {items.map((item, i) => (
    <details name={name} open={openFirst && i === 0}>
      <summary>
        <span class="t-h4">{item.titel}</span>
        <Icon name="chevron-down" size={28} class="acc-chev" />
      </summary>
      <div class="accordion__body"><p class="t-body">{item.text}</p></div>
    </details>
  ))}
</div>

<style>
  .accordion { display: flex; flex-direction: column; }
  .accordion--dividers details { border-bottom: 1px solid var(--light-grey); }
  .accordion summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-s);
    padding: var(--gap-xs) var(--gap-sm);
    color: var(--text);
  }
  .accordion summary::-webkit-details-marker { display: none; }
  .accordion :global(.acc-chev) { color: var(--bronze); transition: transform 0.25s ease; flex: none; }
  .accordion details[open] summary :global(.acc-chev) { transform: rotate(180deg); }
  .accordion__body { padding: 0 var(--gap-sm) var(--gap-xs); }
  .accordion__body .t-body { color: var(--text); }
</style>
